@model Business.DTOs.Output.OwnerDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Trang Bán Hàng - Nhân Viên";
    var theme = ViewBag.ThemeConfig as Core.Entities.CauHinhHeThong;
    var tenCuaHang = theme?.TenCuaHang ?? "SMART WAREHOUSE";
    var mauChuDao = theme?.MauChuDao ?? "#2c3e50";
    var mauNhan = theme?.MauNhan ?? "#3498db";
    var mauNen = theme?.MauNen ?? "#f4f6f9";

    var productsJson = Model.DSSanPham != null
        ? System.Text.Json.JsonSerializer.Serialize(Model.DSSanPham.Select(x => new
        {
            MaSP = x.MaSP != null ? x.MaSP.Trim() : "",
            x.TenSP,
            x.MaVach,
            GiaBan = x.GiaBan ?? 0,
            x.DonViTinh,
            SoLuongTon = x.SoLuongTon ?? 0,
            x.TrangThai
        })) : "[]";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Bán Hàng | POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-color: @mauChuDao;
            --accent-color: @mauNhan;
            --bg-light: @mauNen;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            overflow: hidden;
        }

        .sidebar {
            width: 250px;
            background: var(--bg-light);
            height: 100vh;
            position: fixed;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            margin-left: 250px;
            height: 100vh;
            overflow-y: auto;
            padding: 30px;
        }

        .nav-link {
            color: #555;
            padding: 12px 20px;
            margin: 4px 10px;
            border-radius: 8px;
            font-weight: 600;
            display: flex;
            align-items: center;
            cursor: pointer;
        }

            .nav-link i {
                width: 30px;
                font-size: 1.1rem;
            }

            .nav-link.active {
                background-color: var(--primary-color);
                color: white;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            }

        .pos-item-card {
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }

            .pos-item-card:hover {
                border-color: var(--accent-color);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            }
        /* Ẩn bớt thanh cuộn cho đẹp */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-thumb {
            background: #ccc;
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="p-4 border-bottom">
            <h5 class="fw-bold text-primary mb-1"><i class="fas fa-cubes me-2"></i>@tenCuaHang</h5>
            <small class="text-muted">Khu vực Nhân Viên Bán Hàng</small>
        </div>
        <div class="flex-grow-1 py-3">
            <div class="nav flex-column nav-pills" role="tablist">
                <a class="nav-link active" data-bs-toggle="pill" href="#tab-pos" onclick="renderPosProducts()"><i class="fas fa-cash-register"></i> Máy Bán Hàng (POS)</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-products"><i class="fas fa-box"></i> Tra cứu Sản phẩm</a>
            </div>
        </div>
        <div class="p-4 border-top">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;"><i class="fas fa-user-tag"></i></div>
                <div><div class="fw-bold text-dark">@Context.Session.GetString("HoTen")</div><small class="text-success"><i class="fas fa-circle" style="font-size: 8px;"></i> Ca làm việc</small></div>
            </div>
            <a href="/Home/Logout" class="btn btn-outline-danger w-100 btn-sm"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        <div class="tab-content">

            <div class="tab-pane fade show active" id="tab-pos">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-info"><i class="fas fa-cash-register me-2"></i>Bán Hàng Tại Quầy</h3>
                </div>
                <div class="row g-3">
                    <div class="col-md-7">
                        <div class="card h-100 border-0 p-3 shadow-sm">
                            <div class="mb-3">
                                <div class="input-group input-group-lg shadow-sm">
                                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-info"></i></span>
                                    <input type="text" class="form-control border-start-0" id="searchPosProduct" placeholder="Tìm tên sản phẩm, quét mã vạch..." onkeyup="filterPosProducts()">
                                </div>
                            </div>
                            <div class="row g-3" id="posProductGrid" style="max-height: 70vh; overflow-y: auto;"></div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="card h-100 border-0 bg-white shadow-sm p-3 border-top border-4 border-info">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0 text-info"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng hiện tại</h6>
                                <span class="badge bg-primary rounded-pill" id="posTotalQuantity">0 SP</span>
                            </div>
                            <div class="table-responsive flex-grow-1 border rounded bg-light" style="max-height: 45vh; overflow-y: auto;">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="bg-white sticky-top">
                                        <tr class="text-center small text-muted"><th class="text-start ps-3">Sản phẩm</th><th>SL</th><th>Tổng</th><th></th></tr>
                                    </thead>
                                    <tbody id="posCartTable">
                                        <tr><td colspan="4" class="text-center text-muted py-5"><i class="fas fa-cart-arrow-down fa-3x mb-2 opacity-25"></i><br>Chưa có sản phẩm nào.</td></tr>
                                    </tbody>
                                </table>
                            </div>
                            <hr class="border-secondary opacity-25 my-3">
                            <div class="d-flex justify-content-between align-items-end mb-4">
                                <span class="h6 mb-0 fw-bold text-muted">Khách cần trả:</span>
                                <span class="h2 mb-0 fw-bold text-danger" id="posTotalAmount">0 ₫</span>
                            </div>
                            <button class="btn btn-info w-100 py-3 fw-bold text-white fs-5 shadow-sm mb-2" onclick="openPaymentModal()"><i class="fas fa-check-circle me-2"></i> THANH TOÁN (F9)</button>
                            <button class="btn btn-outline-danger w-100 py-2 fw-bold" onclick="clearPosCart()"><i class="fas fa-trash-alt"></i> Hủy đơn (F4)</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-products">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-success"><i class="fas fa-box-open me-2"></i>Bảng Giá Sản Phẩm</h3>
                    <div class="input-group w-25 shadow-sm">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" class="form-control border-start-0" id="searchTableInput" placeholder="Tìm nhanh..." onkeyup="filterTable()">
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-body table-responsive p-0" style="max-height: 75vh; overflow-y: auto;">
                        <table class="table table-hover align-middle text-center mb-0" id="productTable">
                            <thead class="table-light sticky-top">
                                <tr><th>Mã SP</th><th class="text-start">Tên Sản Phẩm</th><th>Mã Vạch</th><th>ĐVT</th><th>Tồn Kho</th><th class="bg-warning bg-opacity-25 text-dark">Giá Bán Lẻ</th><th>Trạng Thái</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.DSSanPham != null && Model.DSSanPham.Any())
                                {
                                    foreach (var item in Model.DSSanPham)
                                    {
                                        <tr>
                                            <td class="fw-bold text-secondary">@item.MaSP</td>
                                            <td class="text-start fw-bold text-primary">@item.TenSP</td>
                                            <td class="text-muted">@(string.IsNullOrEmpty(item.MaVach) ? "---" : item.MaVach)</td>
                                            <td>@item.DonViTinh</td>
                                            <td>
                                                @if (item.SoLuongTon > 10)
                                                {
                                                    <span class="badge bg-success">@item.SoLuongTon</span>
                                                }
                                                else if (item.SoLuongTon > 0)
                                                {

                                                    <span class="badge bg-warning text-dark">@item.SoLuongTon (Sắp hết)</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger">Hết hàng</span>
                                                }
                                            </td>
                                            <td class="text-danger fw-bold fs-5">@(item.GiaBan.HasValue? item.GiaBan.Value.ToString("N0") : "0") đ</td>
                                            <td>
                                                @if (item.TrangThai == true)
                                                {
                                                    <span class="badge border border-success text-success bg-success bg-opacity-10 px-3 py-2"><i class="fas fa-check-circle me-1"></i>Đang bán</span>
                                                }
                                                else
                                                {

                                                    <span class="badge border border-danger text-danger bg-danger bg-opacity-10 px-3 py-2"><i class="fas fa-lock me-1"></i>Ngừng bán</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>

   
    <div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title fw-bold"><i class="fas fa-qrcode me-2"></i>Xác nhận & Thanh toán</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <h3 class="text-danger fw-bold mb-4" id="qrTotalAmount">0 ₫</h3>

                    <div class="bg-light p-3 rounded text-start mb-4 border">
                        <h6 class="fw-bold mb-3 text-secondary"><i class="fas fa-university me-1"></i> Thông tin chuyển khoản</h6>

                        <input type="hidden" id="qrBank" value="@(theme?.NganHang ?? "")">
                        <input type="hidden" id="qrAccount" value="@(theme?.SoTaiKhoan ?? "")">
                        <input type="hidden" id="qrName" value="@(theme?.TenChuTaiKhoan ?? "")">

                        <div class="mb-2">
                            <span class="text-muted small">Ngân hàng:</span>
                            <strong class="text-primary ms-2 fs-5">@(theme?.NganHang ?? "Chưa cấu hình")</strong>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted small">Số tài khoản:</span>
                            <strong class="text-dark ms-2 fs-5">@(theme?.SoTaiKhoan ?? "Chưa cấu hình")</strong>
                        </div>
                        <div>
                            <span class="text-muted small">Chủ tài khoản:</span>
                            <strong class="text-uppercase ms-2">@(theme?.TenChuTaiKhoan ?? "Chưa cấu hình")</strong>
                        </div>
                    </div>

                    <div id="qrImageContainer" style="display: none;">
                        <p class="text-success fw-bold small mb-2"><i class="fas fa-camera me-1"></i> Khách hàng quét mã dưới đây</p>
                        <img id="qrImage" src="" alt="Mã QR" class="img-fluid border border-2 border-info p-2 rounded bg-white shadow-sm" style="max-width: 250px;">
                    </div>

                    <div class="mt-3">
                        <textarea id="posNote" class="form-control mb-3" rows="2" placeholder="Ghi chú hóa đơn (Ví dụ: Khách chuyển khoản, Tiền mặt...)..." oninput="generateQR()"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Thoát</button>
                    <button type="button" class="btn btn-info fw-bold text-white px-4" onclick="confirmPaymentAndSave()"><i class="fas fa-check-circle me-1"></i> Xác nhận & Lưu HĐ</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        var allProducts = @Html.Raw(productsJson);
        var posCart = [];

        document.addEventListener("DOMContentLoaded", function () {
            renderPosProducts();
        });

        // LOGIC TÌM KIẾM TRONG BẢNG SẢN PHẨM
        function filterTable() {
            var input = document.getElementById("searchTableInput").value.toLowerCase();
            var rows = document.querySelectorAll("#productTable tbody tr");
            rows.forEach(row => {
                var text = row.innerText.toLowerCase();
                row.style.display = text.includes(input) ? "" : "none";
            });
        }

        // ============================================================
        // LOGIC BÁN HÀNG (POS) GIỮ NGUYÊN HOÀN TOÀN
        // ============================================================
        function renderPosProducts() {
            var grid = document.getElementById("posProductGrid"); if (!grid) return;
            var keyword = document.getElementById("searchPosProduct").value.toLowerCase();
            grid.innerHTML = "";
            var filtered = allProducts.filter(p => p.TrangThai === true && p.SoLuongTon > 0 && (p.TenSP.toLowerCase().includes(keyword) || p.MaSP.toLowerCase().includes(keyword)));
            if(filtered.length === 0) { grid.innerHTML = `<div class="col-12 py-5 text-center text-muted">Không tìm thấy sản phẩm.</div>`; return; }
            filtered.forEach(p => {
                grid.innerHTML += `<div class="col-md-4 col-sm-6"><div class="card h-100 pos-item-card position-relative" onclick="addToPosCart('${p.MaSP}')"><div class="card-body p-3 text-center"><span class="badge bg-success position-absolute top-0 end-0 m-2">Tồn: ${p.SoLuongTon}</span><div class="mb-2"><i class="fas fa-box fa-3x text-info opacity-75"></i></div><h6 class="fw-bold mb-1 text-truncate" title="${p.TenSP}">${p.TenSP}</h6><p class="text-danger fw-bold mb-0 fs-6">${(p.GiaBan).toLocaleString()} ₫</p></div></div></div>`;
            });
        }

        function filterPosProducts() { renderPosProducts(); }

        function addToPosCart(maSP) {
            var p = allProducts.find(x => x.MaSP === maSP); if(!p) return;
            var item = posCart.find(x => x.MaSP === maSP);
            if(item) { if(item.SoLuong + 1 > p.SoLuongTon) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Vượt quá tồn!', showConfirmButton: false, timer: 2000}); return; } item.SoLuong++; }
            else { posCart.push({ MaSP: p.MaSP, TenSP: p.TenSP, GiaBan: p.GiaBan, SoLuong: 1, TonKho: p.SoLuongTon }); }
            Swal.fire({toast:true, position: 'top-end', icon: 'success', title: 'Đã thêm', showConfirmButton: false, timer: 500}); updatePosUI();
        }

        function updatePosUI() {
            var tbody = document.getElementById("posCartTable"); tbody.innerHTML = ""; var totalQ = 0; var totalM = 0;
            if(posCart.length === 0) { tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5">Chưa có sản phẩm.</td></tr>`; }
            else {
                posCart.forEach((c, i) => {
                    totalQ += parseInt(c.SoLuong); totalM += (c.SoLuong * c.GiaBan);
                    tbody.innerHTML += `<tr class="text-center"><td class="text-start ps-3"><div class="fw-bold text-dark text-truncate" style="max-width: 120px;">${c.TenSP}</div></td><td><div class="d-flex align-items-center justify-content-center"><button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${i}, -1)"><i class="fas fa-minus"></i></button><input type="number" class="form-control form-control-sm text-center mx-1 fw-bold border bg-white" value="${c.SoLuong}" style="width: 50px;" onchange="updatePosQtyDirect(${i}, this.value)" onclick="this.select()"><button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${i}, 1)"><i class="fas fa-plus"></i></button></div></td><td class="fw-bold text-danger">${(c.GiaBan * c.SoLuong).toLocaleString()}</td><td><button class="btn btn-sm text-danger" onclick="removePosItem(${i})"><i class="fas fa-times"></i></button></td></tr>`;
                });
            }
            document.getElementById("posTotalQuantity").innerText = totalQ + " SP"; document.getElementById("posTotalAmount").innerText = totalM.toLocaleString() + " ₫";
        }

        function updatePosQtyDirect(i, val) {
            var item = posCart[i]; var newQty = parseInt(val);
            if (isNaN(newQty) || newQty <= 0) newQty = 1;
            if (newQty > item.TonKho) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Kho chỉ còn ' + item.TonKho, showConfirmButton: false, timer: 3000}); newQty = item.TonKho; }
            item.SoLuong = newQty; updatePosUI();
        }

        function changePosQty(i, amt) { var item = posCart[i]; var newQty = item.SoLuong + amt; if(newQty <= 0) { removePosItem(i); return; } if(newQty > item.TonKho) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Hết hàng!', showConfirmButton: false, timer: 2000}); return; } item.SoLuong = newQty; updatePosUI(); }
        function removePosItem(i) { posCart.splice(i, 1); updatePosUI(); }
        function clearPosCart() { if(posCart.length === 0) return; Swal.fire({title: 'Hủy đơn?', icon: 'warning', showCancelButton: true}).then((res) => { if (res.isConfirmed) { posCart = []; updatePosUI(); } }); }

        function openPaymentModal() {
              if(posCart.length === 0) return;

              // Tính tổng tiền hiển thị lên UI
              var total = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);
              document.getElementById('qrTotalAmount').innerText = total.toLocaleString() + ' ₫';

              // Gọi hàm sinh QR code (Nó sẽ tự lấy cấu hình ẩn ở trên để vẽ)
              generateQR();

              // Mở bảng thanh toán
              new bootstrap.Modal(document.getElementById('paymentModal')).show();
          }

          // Hàm tự động vẽ QR Code cho nhân viên Sale
          function generateQR() {
              var bank = document.getElementById('qrBank').value;
              var acc = document.getElementById('qrAccount').value;
              var name = document.getElementById('qrName').value;
              var note = document.getElementById("posNote").value || "Thanh toan mua hang";
              var totalM = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);

              // Nếu Boss có cài đặt STK thì mới vẽ QR
              if(bank && acc && totalM > 0) {
                  var qrUrl = `https://img.vietqr.io/image/${bank}-${acc}-compact2.png?amount=${totalM}&addInfo=${encodeURIComponent(note)}&accountName=${encodeURIComponent(name)}`;
                  document.getElementById('qrImage').src = qrUrl;
                  document.getElementById('qrImageContainer').style.display = 'block';
              } else {
                  document.getElementById('qrImageContainer').style.display = 'none';
              }
          }

        function confirmPaymentAndSave() {
            bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
            Swal.fire({ title: 'Đang xử lý...', didOpen: () => Swal.showLoading() });

            // CHÚ Ý CHỖ NÀY LÀ GỌI VÀO API CỦA OWNER (Hoặc API chung của Boss)
            fetch('/Owner/ProcessPosCheckout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    GhiChu: document.getElementById("posNote").value,
                    CartItems: posCart.map(c => ({ MaSP: c.MaSP, SoLuong: c.SoLuong, GiaBan: c.GiaBan }))
                })
            }).then(res => res.json()).then(data => {
                if(data.success) { Swal.fire("Thành công!", "Mã HĐ: " + data.maHD, "success").then(() => location.reload()); }
                else { Swal.fire("Lỗi", data.msg, "error"); }
            });
        }
        // ============================================================
        // NHÂN VIÊN SALE LẮNG NGHE TÍN HIỆU TỪ BOSS (SIGNAL-R)
        // ============================================================

        var connection = new signalR.HubConnectionBuilder().withUrl("/storeHub").build();

        connection.on("ProductUpdated", function (maSP, tenSP, giaBan, trangThai) {
            console.log("⚡ Nhận lệnh từ Boss: Cập nhật " + tenSP);

            // Tìm sản phẩm bị đổi giá trong trí nhớ của máy POS
            var p = allProducts.find(x => x.MaSP === maSP || x.maSP === maSP);

            if (p) {
                // Cập nhật giá, tên và trạng thái mới mà Boss vừa đổi
                p.TenSP = tenSP;
                p.GiaBan = giaBan;
                p.TrangThai = trangThai;

                // Gọi hàm quét lại màn hình để in giá mới ra ngay lập tức
                renderPosProducts();

                // Nảy thông báo cho nhân viên Sale biết để báo khách
                Swal.fire({
                    toast: true, position: 'top-end', icon: 'warning',
                    title: '⚡ Giá sản phẩm [' + tenSP + '] vừa được cập nhật!',
                    showConfirmButton: false, timer: 4000
                });
            }
        });

        // Bật công tắc kết nối
        connection.start().then(function () {
            console.log("🟢 Máy POS đã kết nối Real-time với hệ thống!");
        }).catch(function (err) {
            console.error("🔴 Lỗi mất sóng: " + err.toString());
        });
    </script>
</body>
</html>