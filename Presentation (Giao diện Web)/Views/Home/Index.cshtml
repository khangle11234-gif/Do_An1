@model Business.DTOs.Input.LoginRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống | Smart Warehouse</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(4px);
        }

        .login-box {
            position: relative;
            width: 400px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 20px;
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(15px);
            color: white;
            z-index: 1;
        }

        /* Shake Effect */
        .shake {
            animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
            border: 1px solid #ff4d4d;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.5);
        }

        @@keyframes shake {
            10%, 90% {
                transform: translate3d(-1px, 0, 0);
            }

            20%, 80% {
                transform: translate3d(2px, 0, 0);
            }

            30%, 50%, 70% {
                transform: translate3d(-4px, 0, 0);
            }

            40%, 60% {
                transform: translate3d(4px, 0, 0);
            }
        }

        h2 {
            text-align: center;
            margin-bottom: 30px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .input-group {
            position: relative;
            margin-bottom: 25px;
        }

            .input-group input {
                width: 100%;
                padding: 10px 0;
                font-size: 16px;
                color: #fff;
                border: none;
                border-bottom: 1px solid #fff;
                background: transparent;
                outline: none;
            }

            .input-group label {
                position: absolute;
                top: 0;
                left: 0;
                padding: 10px 0;
                font-size: 16px;
                color: #ddd;
                pointer-events: none;
                transition: 0.5s;
            }

            .input-group input:focus ~ label, .input-group input:valid ~ label {
                top: -20px;
                left: 0;
                color: #03e9f4;
                font-size: 12px;
            }

        .forgot-pass-container {
            text-align: right;
            margin-top: 5px;
            margin-bottom: 20px;
            position: relative;
            z-index: 10;
        }

        .forgot-link {
            color: #fff;
            font-size: 13px;
            font-style: italic;
            text-decoration: none;
            cursor: pointer;
            transition: 0.3s;
            background: rgba(0,0,0,0.2);
            padding: 2px 8px;
            border-radius: 4px;
        }

            .forgot-link:hover {
                color: #03e9f4;
                background: rgba(0,0,0,0.5);
            }

        .btn-submit {
            padding: 10px 20px;
            background: #03e9f4;
            border: none;
            border-radius: 5px;
            width: 100%;
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.5s;
            box-shadow: 0 0 5px #03e9f4;
        }

            .btn-submit:hover {
                background: #fff;
                color: #03e9f4;
                box-shadow: 0 0 20px #03e9f4;
            }

        /* Alert Styles */
        .alert-error {
            background: rgba(220, 53, 69, 0.8);
            color: white;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            font-size: 14px;
            border: 1px solid #ff6b6b;
            animation: slideDown 0.3s ease-out;
        }

        .alert-success {
            background: rgba(40, 167, 69, 0.8);
            color: white;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            border: 1px solid #28a745;
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Modal Styles */
        .custom-modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
        }

        .custom-modal-content {
            background: #222;
            margin: 15% auto;
            padding: 30px;
            border: 1px solid #03e9f4;
            width: 90%;
            max-width: 400px;
            border-radius: 15px;
            box-shadow: 0 0 20px rgba(3, 233, 244, 0.5);
            position: relative;
            color: white;
            animation: slideDown 0.4s;
        }

        .close-btn {
            color: #aaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }

            .close-btn:hover {
                color: #03e9f4;
            }
    </style>
</head>
<body>
    <div class="overlay"></div>

    <div class="login-box" id="loginCard">
        <h2>ĐĂNG NHẬP</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error"><i class="fas fa-times-circle"></i> @ViewBag.Error</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-error"><i class="fas fa-exclamation-triangle"></i> @TempData["Error"]</div>
        }
        @if (TempData["Message"] != null)
        {
            <div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["Message"]</div>
        }

        <form asp-action="Index" method="post">
            <div class="input-group">
                <input asp-for="TenDangNhap" type="text" required autocomplete="off">
                <label>Tên đăng nhập</label>
            </div>

            <div class="input-group">
                <input asp-for="MatKhau" type="password" required>
                <label>Mật khẩu</label>
            </div>

            <div class="forgot-pass-container">
                <a class="forgot-link" onclick="openModal()">
                    <i class="fas fa-key"></i> Quên mật khẩu?
                </a>
            </div>

            <button type="submit" class="btn-submit">VÀO HỆ THỐNG</button>
        </form>
    </div>

    <div id="forgotModal" class="custom-modal">
        <div class="custom-modal-content">
            <span class="close-btn" onclick="closeModal()">&times;</span>
            <h3 style="text-align: center; color: #03e9f4; margin-bottom: 20px;">TÌM TÀI KHOẢN</h3>

            <p style="text-align: center; color: #ccc; font-size: 13px; margin-bottom: 25px;">
                Vui lòng nhập <b>Tên tài khoản</b> và <b>Email</b> để xác minh danh tính.
            </p>

            <form action="/Home/ForgotPassword" method="post">
                <div class="input-group" style="margin-bottom: 20px;">
                    <input type="text" name="username" required autocomplete="off">
                    <label>Tên đăng nhập</label>
                </div>

                <div class="input-group" style="margin-bottom: 20px;">
                    <input type="email" name="email" required autocomplete="off">
                    <label>Email đã đăng ký</label>
                </div>

                <button type="submit" class="btn-submit" style="margin-top: 10px;">GỬI YÊU CẦU</button>
            </form>
        </div>
    </div>

    <script>
        function openModal() { document.getElementById("forgotModal").style.display = "block"; }
        function closeModal() { document.getElementById("forgotModal").style.display = "none"; }
        window.onclick = function(e) { if (e.target == document.getElementById("forgotModal")) closeModal(); }

        window.onload = function() {
            var hasError = "@ViewBag.Error";
            if (hasError && hasError.length > 0) {
                var card = document.getElementById("loginCard");
                card.classList.add("shake");
                setTimeout(function() { card.classList.remove("shake"); }, 500);
            }
        };
    </script>
</body>
</html>