@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Quản Lý Kho</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-secondary mb-4">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">🏭 QUẢN LÝ KHO VẬT TƯ</span>
            <a href="/Home/Logout" class="btn btn-light btn-sm">Đăng xuất</a>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-3">
                <div class="card text-white bg-success mb-3">
                    <div class="card-header">Tổng Nhập</div>
                    <div class="card-body">
                        <h3 class="card-title">150 Phiếu</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning mb-3">
                    <div class="card-header">Sắp hết hàng</div>
                    <div class="card-body">
                        <h3 class="card-title">05 SP</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5>📦 Danh sách tồn kho hiện tại</h5>
            </div>
            <div class="card-body">
                <button class="btn btn-primary mb-3">📥 Tạo Phiếu Nhập Kho</button>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Mã VT</th>
                            <th>Tên Vật Tư</th>
                            <th>Đơn vị</th>
                            <th>Tồn kho</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>XM01</td>
                            <td>Xi măng Hà Tiên</td>
                            <td>Bao</td>
                            <td><strong>500</strong></td>
                            <td><span class="badge bg-success">Đủ hàng</span></td>
                        </tr>
                        <tr>
                            <td>THEP01</td>
                            <td>Thép Hòa Phát</td>
                            <td>Kg</td>
                            <td class="text-danger"><strong>20</strong></td>
                            <td><span class="badge bg-danger">Sắp hết</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>
</html>