        var inputBarcode = document.getElementById("scanBarcode");
        if(inputBarcode){
            inputBarcode.addEventListener("keyup", function(e) {
                if (e.key === "Enter") {
                    var code = this.value.trim();
                    var p = allProducts.find(x => x.MaVach === code);
