                                                <small id="status_text_@maSP" class="text-muted fw-bold mt-1 d-block @(item.TrangThai == true ? "text-success" : "text-danger")">@(item.TrangThai == true ? "Đang bán" : "Ngừng bán")</small>
                                            </td>
                                            <td>
                                                <button class="btn btn-action text-warning me-1" onclick="openEditProductModal('@maSP')" title="Sửa Sản Phẩm"><i class="fas fa-edit"></i></button>
