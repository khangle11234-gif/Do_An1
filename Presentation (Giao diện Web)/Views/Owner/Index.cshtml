                        <i class="fas fa-plus me-2"></i>Thêm NCC Mới
                    </button>
                </div>

                <div class="card stat-card border-0">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover table-custom align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã NCC</th>
                                    <th>Tên Nhà Cung Cấp</th>
                                    <th>Số Điện Thoại</th>
                                    <th>Địa Chỉ</th>
                                    <th>Ghi Chú</th>
                                    <th class="text-end pe-4">Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DSNhaCungCap != null && Model.DSNhaCungCap.Any())
                                {
                                    foreach (var ncc in Model.DSNhaCungCap)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-muted">@ncc.MaNCC</td>
                                            <td class="fw-bold text-primary">@ncc.TenNCC</td>
                                            <td><span class="badge bg-light text-dark border"><i class="fas fa-phone-alt me-1 text-muted"></i>@(string.IsNullOrEmpty(ncc.SDT) ? "---" : ncc.SDT)</span></td>
                                            <td>@(string.IsNullOrEmpty(ncc.DiaChi) ? "---" : ncc.DiaChi)</td>
                                            <td class="text-muted small">@ncc.GhiChu</td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-action text-warning me-1" data-bs-toggle="modal" data-bs-target="#editNCC_@ncc.MaNCC" title="Sửa thông tin"><i class="fas fa-edit"></i></button>
                                                <button class="btn btn-action text-danger" onclick="deleteSupplier('@ncc.MaNCC')" title="Xóa"><i class="fas fa-trash-alt"></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-5"><i class="fas fa-user-slash fa-3x mb-3 opacity-25"></i><br />Chưa có nhà cung cấp nào.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (Model.DSNhaCungCap != null && Model.DSNhaCungCap.Any())
                {
                    foreach (var ncc in Model.DSNhaCungCap)
                    {
                        <div class="modal fade" id="editNCC_@ncc.MaNCC" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content border-0 shadow-lg">
                                    <form id="formEditNCC_@ncc.MaNCC" onsubmit="submitEditSupplier(event, '@ncc.MaNCC')">
                                        <div class="modal-header bg-secondary text-white">
                                            <h5 class="modal-title fw-bold"><i class="fas fa-edit me-2"></i>Sửa thông tin: @ncc.TenNCC</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body p-4">
