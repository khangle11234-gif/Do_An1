          // 4. Kịch bản 2: Tự động vẽ Tem QR khi nhập Số Lô
          function generateLotQR() {
              var maSP = document.getElementById("new_MaSP").value;
              var soLo = document.getElementById("new_SoLo").value;

              if(maSP && soLo) {
                  var fullCode = maSP + "-" + soLo; // VD: THE-PM-0008-L9988

                  // Dùng API miễn phí để vẽ QR
                  var qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(fullCode)}`;
                  document.getElementById("lotQrImage").src = qrUrl;
