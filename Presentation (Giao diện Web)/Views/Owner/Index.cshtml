            .withUrl("/storeHub")
            .build();

        // 2. Mở "lỗ tai" lắng nghe tín hiệu có tên "ProductUpdated" từ C# (OwnerController) gửi xuống
        connection.on("ProductUpdated", function (maSP, tenSP, giaBan, trangThai) {

            console.log("⚡ SignalR báo cáo: Có sự thay đổi ở sản phẩm " + maSP);

            // --- HÀNH ĐỘNG A: CẬP NHẬT BẢNG SẢN PHẨM KHÔNG CẦN F5 ---
            var priceElement = document.getElementById("price_text_" + maSP);
            if (priceElement) priceElement.innerText = giaBan.toLocaleString() + " đ";

            var nameElement = document.getElementById("name_text_" + maSP);
            if (nameElement) nameElement.innerText = tenSP;

            var statusElement = document.getElementById("status_text_" + maSP);
            var switchElement = document.getElementById("switch_" + maSP);
            if(statusElement && switchElement) {
                if(trangThai) {
                    statusElement.innerText = "Đang bán";
                    statusElement.className = "text-muted fw-bold mt-1 d-block text-success";
                    switchElement.checked = true;
                } else {
                    statusElement.innerText = "Ngừng bán";
                    statusElement.className = "text-muted fw-bold mt-1 d-block text-danger";
                    switchElement.checked = false;
                }
            }

            // --- HÀNH ĐỘNG B: CẬP NHẬT TRÍ NHỚ CỦA MÁY TÍNH TIỀN (POS) ---
            // Tìm sản phẩm trong mảng RAM của máy tính tiền
            var p = allProducts.find(x => x.MaSP === maSP || x.maSP === maSP);
            if (p) {
                // Đổi dữ liệu trong RAM
                p.TenSP = tenSP;
                p.GiaBan = giaBan;
                p.TrangThai = trangThai;

                // Kích hoạt hàm vẽ lại các ô sản phẩm POS ngay lập tức
                renderPosProducts();

                // Hiện thông báo nhỏ trên góc màn hình cho nhân viên/boss biết
                Swal.fire({
                    toast: true, position: 'top-end', icon: 'info',
                    title: '⚡ Cập nhật tự động: Giá mới cho ' + tenSP,
                    showConfirmButton: false, timer: 3500
                });
            }
        });

        // 3. Bật công tắc, bắt đầu kết nối với máy chủ
        connection.start().then(function () {
            console.log("🟢 SignalR: Đã kết nối thành công trạm thời gian thực!");
        }).catch(function (err) {
            console.error("🔴 SignalR Lỗi Kết Nối: " + err.toString());
        });
    </script>
</body>
</html>