                                    <input type="number" class="form-control form-control-sm fw-bold d-none" id="chartYearPicker" value="@DateTime.Now.Year" min="2000" max="2100" style="width: 100px;">
                                    <button class="btn btn-primary btn-sm fw-bold px-3" onclick="loadDynamicChart()"><i class="fas fa-filter"></i></button>
                                </div>
                            </div>
                            <div id="dynamicChartArea">
                                <div class="text-center py-5 text-muted">
                                    <div class="spinner-border text-primary mb-3"></div><br>
                                    Đang tải biểu đồ...
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card stat-card h-100 shadow-sm border-0">
                            <h6 class="fw-bold text-secondary mb-3" id="topProductsTitle"><i class="fas fa-star me-2 text-warning"></i>Top 5 Lợi Nhuận (All-time)</h6>
                            <ul class="list-group list-group-flush mt-2" id="topProductsList">
                                @if (Model.DSSanPham != null)
                                {
                                    var topProducts = Model.DSSanPham
                                    .Where(x => x.GiaBan > 0 && x.GiaNhap > 0)
                                    .OrderByDescending(x => x.GiaBan - x.GiaNhap)
                                    .Take(5)
                                    .ToList();

                                    if (topProducts.Any())
                                    {
                                        foreach (var sp in topProducts)
                                        {
                                            decimal lai = (sp.GiaBan ?? 0) - (sp.GiaNhap ?? 0);
                                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-bottom mb-2 pb-2">
                                                <div>
                                                    <div class="fw-bold text-dark text-truncate" style="max-width: 180px;" title="@sp.TenSP">@sp.TenSP</div>
                                                    <small class="text-success fw-bold"><i class="fas fa-arrow-trend-up me-1"></i>Lãi: @lai.ToString("N0") ₫ / SP</small>
                                                </div>
                                                <span class="badge bg-warning text-dark rounded-pill border">VIP</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-center text-muted mt-4">Chưa có dữ liệu.</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
