@model Business.DTOs.Output.OwnerDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Trang Chủ Doanh Nghiệp";
    var currentUserId = Context.Session.GetString("MaND");
    var theme = ViewBag.ThemeConfig as Core.Entities.CauHinhHeThong;
    var tenCuaHang = theme?.TenCuaHang ?? "SMART WAREHOUSE";
    var mauChuDao = theme?.MauChuDao ?? "#2c3e50";
    var mauNhan = theme?.MauNhan ?? "#3498db";
    var mauNen = theme?.MauNen ?? "#f4f6f9";

    // Thêm Trim() để xóa khoảng trắng dư thừa từ SQL
    var productsJson = Model.DSSanPham != null
        ? System.Text.Json.JsonSerializer.Serialize(Model.DSSanPham.Select(x => new
        {
            MaSP = x.MaSP != null ? x.MaSP.Trim() : "",
            x.TenSP,
            x.MaVach,
            x.GiaNhap,
            GiaBan = x.GiaBan ?? 0,
            x.DonViTinh,
            SoLuongTon = x.SoLuongTon ?? 0,
            TrangThai = x.TrangThai ?? false
        }))
        : "[]";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Quản Lý Doanh Nghiệp | Owner Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            /* Đồng bộ biến màu từ Database */
            --primary-color: @mauChuDao;
            --accent-color: @mauNhan;
            --bg-light: @mauNen;
        }

        /* ========================================================== */
        /* ĐỒNG BỘ MÀU BẢNG, CARD VÀ SIDEBAR CHO TIỆP MÀU NỀN MƯỢT MÀ */
        /* ========================================================== */

        .card:not(.bg-primary):not(.bg-success):not(.bg-danger):not(.bg-info):not(.bg-warning),
        .stat-card:not(.bg-primary):not(.bg-success):not(.bg-danger):not(.bg-info):not(.bg-warning),
        .modal-content, .sidebar {
            background-color: var(--bg-light) !important;
        }

        .bg-white {
            background-color: var(--bg-light) !important;
        }

        .table {
            --bs-table-bg: transparent !important;
        }

        .table-custom th, .table-light th {
            background-color: rgba(0,0,0,0.03) !important;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .table-custom td, .table td {
            background-color: transparent !important;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .table-hover > tbody > tr:hover > * {
            background-color: rgba(0,0,0,0.05) !important;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: var(--bg-light);
            height: 100vh;
            position: fixed;
            box-shadow: 2px 0 10px rgba(0,0,0,0.05);
            z-index: 1000;
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 25px 20px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            flex-shrink: 0;
        }

            .sidebar-header h5 {
                font-weight: 800;
                color: var(--primary-color);
                margin: 0;
                letter-spacing: -0.5px;
            }

        .sidebar-menu-area {
            flex-grow: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 15px 0;
        }

            .sidebar-menu-area::-webkit-scrollbar {
                width: 5px;
            }

            .sidebar-menu-area::-webkit-scrollbar-thumb {
                background-color: rgba(0,0,0,0.1);
                border-radius: 4px;
            }

            .sidebar-menu-area:hover::-webkit-scrollbar-thumb {
                background-color: rgba(0,0,0,0.2);
            }

        .sidebar-footer {
            border-top: 1px solid rgba(0,0,0,0.05);
            padding: 20px;
            flex-shrink: 0;
        }

        /* MAIN CONTENT */
        .main-content {
            margin-left: 260px;
            height: 100vh;
            overflow-y: auto;
            padding: 30px;
        }

        /* NAV LINKS */
        .nav-link {
            color: #555;
            padding: 12px 20px;
            margin: 4px 10px;
            border-radius: 8px;
            font-weight: 500;
            display: flex;
            align-items: center;
            transition: all 0.2s;
            cursor: pointer;
        }

            .nav-link i {
                width: 30px;
                font-size: 1.1rem;
                color: #95a5a6;
            }

            .nav-link:hover {
                background-color: rgba(0,0,0,0.03);
                color: var(--primary-color);
            }

                .nav-link:hover i {
                    color: var(--accent-color);
                }

            .nav-link.active {
                background-color: var(--primary-color);
                color: white;
                box-shadow: 0 4px 6px rgba(44, 62, 80, 0.2);
            }

                .nav-link.active i {
                    color: #ecf0f1;
                }

        /* UI ELEMENTS */
        .stat-card {
            border-radius: 12px;
            padding: 25px;
            border: none;
            box-shadow: 0 2px 15px rgba(0,0,0,0.03);
            transition: transform 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
            }

        .icon-box {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .section-title {
            font-weight: 700;
            color: var(--primary-color);
            font-size: 1.5rem;
        }

        /* TABLE & BUTTONS */
        .btn-action {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(0,0,0,0.1);
            background: var(--bg-light);
            transition: 0.2s;
        }

            .btn-action:hover {
                background: rgba(0,0,0,0.05);
            }

        .input-compact {
            padding: 5px 10px;
            font-size: 0.9rem;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 4px;
            width: 100%;
            background: transparent;
        }

            .input-compact:focus {
                border-color: var(--accent-color);
                outline: none;
            }

        .product-link {
            cursor: pointer;
            text-decoration: none;
            transition: color 0.2s;
        }

            .product-link:hover {
                text-decoration: underline;
                color: var(--accent-color) !important;
            }

        #searchResults {
            max-height: 300px;
            overflow-y: auto;
        }

        .list-group-item-action:hover {
            background-color: rgba(0,0,0,0.03);
        }

        /* POS STYLES */
        .pos-item-card {
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            cursor: pointer;
            transition: 0.2s;
        }

            .pos-item-card:hover {
                border-color: var(--accent-color);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            }

        .pos-qty-input::-webkit-outer-spin-button, .pos-qty-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Hiệu ứng hover cho cột biểu đồ */
        .chart-bar:hover {
            opacity: 0.8 !important;
            transform: scaleY(1.02);
        }

        .list-group-item {
            background: transparent !important;
            border-color: rgba(0,0,0,0.05) !important;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <h5><i class="fas fa-cubes me-2"></i>@tenCuaHang</h5>
            <small>Khu vực Chủ Doanh Nghiệp</small>
        </div>

        <div class="sidebar-menu-area">
            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist">
                <small class="text-uppercase fw-bold text-muted px-4 mb-2" style="font-size: 0.75rem;">Quản trị</small>
                <a class="nav-link active" data-bs-toggle="pill" href="#tab-dashboard"><i class="fas fa-chart-line"></i> Tổng quan (Dashboard)</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-employees" id="link-tab-employees"><i class="fas fa-users-cog"></i> Quản lý Nhân sự</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-finance"><i class="fas fa-wallet"></i> Tài chính & Lợi nhuận</a>

                <small class="text-uppercase fw-bold text-muted px-4 mb-2 mt-3" style="font-size: 0.75rem;">Nghiệp vụ</small>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-import"><i class="fas fa-truck-loading"></i> Nhập hàng hóa</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-pos" id="link-tab-pos" onclick="renderPosProducts()"><i class="fas fa-cash-register"></i> Bán hàng (POS)</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-warehouse"><i class="fas fa-warehouse"></i> Tồn kho & Kiểm kê</a>

                <small class="text-uppercase fw-bold text-muted px-4 mb-2 mt-3" style="font-size: 0.75rem;">Dữ liệu</small>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-products"><i class="fas fa-box"></i> Sản phẩm & Giá</a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-partners"><i class="fas fa-users"></i> Nhà Cung Cấp</a>
            </div>
        </div>

        <div class="sidebar-footer">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;"><i class="fas fa-user-tie"></i></div>
                <div><div class="fw-bold text-dark">@Context.Session.GetString("HoTen")</div><small class="text-success"><i class="fas fa-circle" style="font-size: 8px;"></i> Online</small></div>
            </div>
            <a href="/Home/Logout" class="btn btn-outline-danger w-100 btn-sm"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a>
        </div>
    </div>

    <div class="main-content">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm"><i class="fas fa-check-circle me-2"></i> @TempData["Message"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4 shadow-sm"><i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        }

        <div class="tab-content" id="v-pills-tabContent">

            <div class="tab-pane fade show active" id="tab-dashboard">
                <div class="section-header">
                    <div class="section-title text-primary"><i class="fas fa-chart-line me-2"></i>Tổng quan hệ thống</div>
                    <button class="btn btn-light border shadow-sm" onclick="window.location.reload()">
                        <i class="fas fa-sync-alt me-2"></i>Cập nhật số liệu
                    </button>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="stat-card shadow-sm border-0 border-bottom border-4 border-primary">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="text-muted mb-0 fw-bold">Tổng Nhân Sự</h6>
                                <div class="icon-box bg-primary bg-opacity-10 text-primary mb-0" style="width:40px; height:40px; font-size:1.2rem;"><i class="fas fa-users"></i></div>
                            </div>
                            <h3 class="fw-bold text-dark mb-1">@(Model.DanhSachNhanVien?.Count ?? 0) <span class="fs-6 text-muted fw-normal">người</span></h3>
                            <small class="text-primary"><i class="fas fa-info-circle me-1"></i>Đang hoạt động</small>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card shadow-sm border-0 border-bottom border-4 border-danger">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="text-muted mb-0 fw-bold">Cần Nhập Hàng</h6>
                                <div class="icon-box bg-danger bg-opacity-10 text-danger mb-0" style="width:40px; height:40px; font-size:1.2rem;"><i class="fas fa-box-open"></i></div>
                            </div>
                            <h3 class="fw-bold text-dark mb-1">@(Model.DSSanPham.Count(x => (x.SoLuongTon ?? 0) <= 10)) <span class="fs-6 text-muted fw-normal">món</span></h3>
                            <small class="text-danger fw-bold"><i class="fas fa-exclamation-triangle me-1"></i>Tồn kho &le; 10</small>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card shadow-sm border-0 border-bottom border-4 border-info">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="text-muted mb-0 fw-bold">Nhà Cung Cấp</h6>
                                <div class="icon-box bg-info bg-opacity-10 text-info mb-0" style="width:40px; height:40px; font-size:1.2rem;"><i class="fas fa-handshake"></i></div>
                            </div>
                            <h3 class="fw-bold text-dark mb-1">@(Model.DSNhaCungCap?.Count ?? 0) <span class="fs-6 text-muted fw-normal">đối tác</span></h3>
                            <small class="text-info"><i class="fas fa-link me-1"></i>Sẵn sàng giao dịch</small>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card shadow-sm border-0 border-bottom border-4 border-success">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="text-muted mb-0 fw-bold">Sản Phẩm Đang Bán</h6>
                                <div class="icon-box bg-success bg-opacity-10 text-success mb-0" style="width:40px; height:40px; font-size:1.2rem;"><i class="fas fa-tags"></i></div>
                            </div>
                            <h3 class="fw-bold text-dark mb-1">@(Model.DSSanPham.Count(x => x.TrangThai == true)) <span class="fs-6 text-muted fw-normal">món</span></h3>
                            <small class="text-success"><i class="fas fa-check-circle me-1"></i>Trạng thái Active</small>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-7">
                        <div class="card stat-card shadow-sm border-0 h-100">
                            <h6 class="fw-bold text-secondary mb-3"><i class="fas fa-users-cog me-2"></i>Đội ngũ nhân sự</h6>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <tbody>
                                        @if (Model.DanhSachNhanVien != null)
                                        {
                                            foreach (var nv in Model.DanhSachNhanVien.Take(4))
                                            {
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" style="width:45px; height:45px; font-size: 1.2rem;">
                                                                @nv.HoTen.Substring(0, 1).ToUpper()
                                                            </div>
                                                            <div>
                                                                <div class="fw-bold text-dark">@nv.HoTen</div>
                                                                <small class="text-muted">@nv.TenDangNhap</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td><span class="badge bg-light text-dark border px-3 py-2">@nv.VaiTro</span></td>
                                                    <td class="text-end">
                                                        @(nv.TrangThai == true ? Html.Raw("<span class='text-success small fw-bold'><i class='fas fa-circle me-1' style='font-size:8px;'></i>Hoạt động</span>") : Html.Raw("<span class='text-danger small fw-bold'><i class='fas fa-lock me-1' style='font-size:8px;'></i>Đã khóa</span>"))
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <div class="card stat-card shadow-lg border-0 h-100 text-white" style="background: linear-gradient(135deg, var(--primary-color), #34495e);">
                            <h6 class="fw-bold mb-4 text-warning"><i class="fas fa-bolt me-2"></i>Thao tác nhanh (Quick Actions)</h6>
                            <div class="d-grid gap-3">
                                <button class="btn btn-light text-primary fw-bold text-start py-3 shadow" onclick="new bootstrap.Tab(document.querySelector('#link-tab-pos')).show(); renderPosProducts();">
                                    <i class="fas fa-cash-register me-3 fs-5 align-middle"></i> Mở Máy Tính Tiền (POS)
                                </button>
                                <button class="btn btn-outline-light fw-bold text-start py-3 border-2" onclick="openProductModal()">
                                    <i class="fas fa-plus-circle me-3 fs-5 align-middle"></i> Thêm Sản Phẩm Mới
                                </button>
                                <button class="btn btn-outline-light fw-bold text-start py-3 border-2" onclick="openAddModal()">
                                    <i class="fas fa-user-plus me-3 fs-5 align-middle"></i> Cấp Tài Khoản Nhân Viên
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-employees">
                <div class="section-header">
                    <div class="section-title">Quản lý Nhân sự</div>
                    <button class="btn btn-primary shadow-sm" onclick="openAddModal()"><i class="fas fa-user-plus me-2"></i>Thêm nhân viên mới</button>
                </div>
                <div class="card stat-card">
                    <div class="table-responsive">
                        <table class="table table-custom table-hover mb-0 text-center">
                            <thead><tr><th class="text-start ps-4">Mã NV</th><th>Tài khoản</th><th>Họ tên</th><th>Vị trí</th><th>Trạng thái</th><th class="text-end pe-4">Hành động</th></tr></thead>
                            <tbody>
                                @if (Model.DanhSachNhanVien != null)
                                {
                                    foreach (var u in Model.DanhSachNhanVien)
                                    {
                                        bool isActive = u.TrangThai == true;
                                        bool isSelf = u.MaND == currentUserId;
                                        <tr class="@(isActive ? "" : "text-muted")">
                                            <td class="text-start ps-4 fw-bold text-secondary">@u.MaND</td>
                                            <td class="fw-bold text-primary">@u.TenDangNhap</td>
                                            <td>@u.HoTen</td>
                                            <td>
                                                @if (u.VaiTro == "Sale")
                                                {
                                                    <span class="badge bg-info bg-opacity-10 text-info px-3">Bán hàng</span>
                                                }
                                                else if (u.VaiTro == "Kho")
                                                {

                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-3">Thủ kho</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3">Quản lý</span>
                                                }
                                            </td>
                                            <td>
                                                @if (isActive)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success px-3">Active</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-3">Locked</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-action text-warning me-1" onclick="openEditModal('@u.MaND', '@u.TenDangNhap', '@u.HoTen', '@u.VaiTro', '@u.MaNhomQuyen', '@u.Email', @(isActive.ToString().ToLower()))"><i class="fas fa-pen"></i></button>
                                                @if (isSelf)
                                                {
                                                    <button class="btn btn-action text-secondary" disabled><i class="fas fa-trash" style="opacity: 0.5;"></i></button>
                                                }
                                                else
                                                {

                                                    <button class="btn btn-action text-danger" onclick="openDeleteModal('@u.MaND', '@u.HoTen')"><i class="fas fa-trash"></i></button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-finance">
                <div class="section-header">
                    <div class="section-title text-success"><i class="fas fa-chart-pie me-2"></i>Báo cáo Tài chính & Lợi nhuận</div>
                    <button class="btn btn-outline-success shadow-sm" onclick="window.print()"><i class="fas fa-print me-2"></i>In Báo Cáo</button>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card stat-card border-start border-4 border-secondary shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-box-open me-2"></i>Tổng vốn hàng đang tồn</h6>
                            <h3 class="fw-bold text-dark mb-0">@(((decimal)ViewBag.TongVonTienHang).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card border-start border-4 border-info shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-tags me-2"></i>Doanh thu ước tính (Bán hết)</h6>
                            <h3 class="fw-bold text-info mb-0">@(((decimal)ViewBag.GiaTriBanUocTinh).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card border-start border-4 border-success shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-hand-holding-usd me-2"></i>Lợi nhuận gộp dự kiến</h6>
                            <h3 class="fw-bold text-success mb-0">@(((decimal)ViewBag.LoiNhuanUocTinh).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card stat-card h-100 shadow-sm border-0">
                            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
