                                            <td class="ps-4 fw-bold text-muted">@ncc.MaNCC</td>
                                            <td class="fw-bold text-primary">@ncc.TenNCC</td>
                                            <td><span class="badge bg-light text-dark border"><i class="fas fa-phone-alt me-1 text-muted"></i>@(string.IsNullOrEmpty(ncc.SDT) ? "---" : ncc.SDT)</span></td>
                                            <td>@(string.IsNullOrEmpty(ncc.DiaChi) ? "---" : ncc.DiaChi)</td>
                                            <td class="text-muted small">@ncc.GhiChu</td>
                                            <td class="text-end pe-4">
