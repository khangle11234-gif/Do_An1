                                    foreach (var item in Model.DSSanPham)
                                    {
                                        int tonKho = item.SoLuongTon ?? 0;
                                        decimal giaNhap = item.GiaNhap ?? 0;
                                        decimal tongGiaTri = tonKho * giaNhap;
                                        string maSP = item.MaSP != null ? item.MaSP.Trim() : "";
                                        <tr>
                                            <td class="fw-bold text-secondary">@maSP</td>
                                            <td class="text-start fw-bold text-primary">@item.TenSP</td>
                                            <td class="text-muted">@giaNhap.ToString("N0") ₫</td>
                                            <td class="fs-5 fw-bold bg-warning bg-opacity-10 text-dark">@tonKho</td>
                                            <td>
                                                @if (tonKho > 10)
                                                {
                                                    <span class="badge bg-success">An toàn</span>
                                                }
                                                else if (tonKho > 0)
