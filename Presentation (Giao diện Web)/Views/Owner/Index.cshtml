          function openKiemKeModal(maSP, tenSP, tonHeThong) {
              // Đổ dữ liệu vào UI
              document.getElementById('kk_MaSP').value = maSP;
              document.getElementById('kk_MaSP_Text').innerText = "Mã SP: " + maSP;
              document.getElementById('kk_TenSP').innerText = tenSP;
              document.getElementById('kk_TonHeThong').innerText = tonHeThong;

              // Focus sẵn vào ô nhập để bắn mã vạch / gõ số nhanh
              var txtThucTe = document.getElementById('kk_TonThucTe');
              txtThucTe.value = tonHeThong;

              // Reset form trạng thái
              document.getElementById('kk_PhanLoaiLyDo').value = "Khớp số lượng";
              document.getElementById('kk_LyDo').value = '';

              calcChenhLech(); // Chạy tính toán ngay lần đầu mở

              var modal = new bootstrap.Modal(document.getElementById('kiemKeModal'));
              modal.show();

              // Tự động bôi đen ô nhập liệu khi form mở lên để gõ luôn không cần xóa
              setTimeout(() => { txtThucTe.focus(); txtThucTe.select(); }, 500);
          }

          function calcChenhLech() {
              var heThong = parseInt(document.getElementById('kk_TonHeThong').innerText) || 0;
              var thucTe = parseInt(document.getElementById('kk_TonThucTe').value);
              var diff = thucTe - heThong;

              var alertBox = document.getElementById('kk_AlertBox');
              var ddlLyDo = document.getElementById('kk_PhanLoaiLyDo');
              var txtLyDo = document.getElementById('kk_LyDo');

              // Nếu người dùng xóa trắng ô nhập liệu
              if (isNaN(thucTe)) {
                  alertBox.className = "p-3 rounded text-center bg-secondary bg-opacity-10";
                  alertBox.innerHTML = `<span class="text-muted fw-bold"><i class="fas fa-keyboard me-2"></i>Đang chờ nhập số...</span>`;
                  ddlLyDo.disabled = true; txtLyDo.disabled = true;
                  return;
              }

              // Mở khóa form lý do nếu có chênh lệch
              if (diff !== 0) {
                  ddlLyDo.disabled = false;
                  txtLyDo.disabled = false;
                  if(ddlLyDo.value === "Khớp số lượng") ddlLyDo.value = diff < 0 ? "Sai sót sổ sách" : "Hàng dư chưa nhập";
              } else {
                  ddlLyDo.disabled = true;
                  txtLyDo.disabled = true;
                  ddlLyDo.value = "Khớp số lượng";
              }

              // Vẽ giao diện báo cáo chênh lệch cực mạnh
              if (diff > 0) {
                  alertBox.className = "p-3 rounded text-center bg-success bg-opacity-10 border border-success";
                  alertBox.innerHTML = `<h5 class="text-success fw-bold mb-0"><i class="fas fa-arrow-up me-2"></i>Dư ${diff} sản phẩm</h5><small class="text-success">Kho thực tế nhiều hơn sổ sách</small>`;
              }
              else if (diff < 0) {
                  alertBox.className = "p-3 rounded text-center bg-danger bg-opacity-10 border border-danger";
                  alertBox.innerHTML = `<h5 class="text-danger fw-bold mb-0"><i class="fas fa-arrow-down me-2"></i>Thiếu ${Math.abs(diff)} sản phẩm</h5><small class="text-danger">Kho thực tế ít hơn sổ sách</small>`;
              }
              else {
                  alertBox.className = "p-3 rounded text-center bg-primary bg-opacity-10 border border-primary";
                  alertBox.innerHTML = `<h5 class="text-primary fw-bold mb-0"><i class="fas fa-check-circle me-2"></i>Khớp 100%</h5><small class="text-primary">Số liệu tuyệt đối chính xác</small>`;
              }
          }

          function submitKiemKe() {
              var maSP = document.getElementById('kk_MaSP').value;
              var thucTe = parseInt(document.getElementById('kk_TonThucTe').value);
              var heThong = parseInt(document.getElementById('kk_TonHeThong').innerText) || 0;

              var phanLoai = document.getElementById('kk_PhanLoaiLyDo').value;
              var lyDoText = document.getElementById('kk_LyDo').value.trim();

              if (isNaN(thucTe) || thucTe < 0) {
                  Swal.fire("Lỗi nhập liệu", "Số lượng đếm được không hợp lệ!", "error"); return;
              }

              // Gộp phân loại và ghi chú lại để ném xuống C# lưu vào cột GhiChu
              var finalGhiChu = (thucTe === heThong) ? "Hệ thống khớp 100%" : `[${phanLoai}] ${lyDoText}`;

              if(thucTe !== heThong && phanLoai === "Khớp số lượng") {
                  Swal.fire("Thiếu thông tin", "Vui lòng chọn Phân loại lý do chênh lệch!", "warning"); return;
              }

              Swal.fire({title: 'Đang chốt sổ...', didOpen: () => Swal.showLoading()});

              fetch('/Owner/KiemKeKhoAPI', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ MaSP: maSP, TonThucTe: thucTe, GhiChu: finalGhiChu })
              })
              .then(res => res.json())
              .then(data => {
                  if(data.success) {
                      bootstrap.Modal.getInstance(document.getElementById('kiemKeModal')).hide();
                      Swal.fire({icon: 'success', title: 'Đã Cân Bằng Kho!', text: 'Số liệu đã được ghi nhận vào lịch sử.', timer: 2000, showConfirmButton: false})
                      .then(() => location.reload());
                  }
                  else { Swal.fire("Lỗi hệ thống", data.msg, "error"); }
              });
          }

