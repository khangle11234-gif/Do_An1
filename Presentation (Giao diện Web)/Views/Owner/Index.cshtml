        var searchInput = document.getElementById("searchProduct");
        var searchRes = document.getElementById("searchResults");
        if(searchInput && searchRes){
            function performSearch() {
                var k = searchInput.value.toLowerCase(); searchRes.innerHTML = "";
                var sourceData = [...allProducts].reverse();
                var matches = k.length < 1 ? sourceData : sourceData.filter(p => p.TenSP.toLowerCase().includes(k) || p.MaSP.toLowerCase().includes(k));
                if(matches.length > 0) {
                    searchRes.style.display = "block";
                    matches.slice(0, 6).forEach(p => {
                        var item = document.createElement("a"); item.className = "list-group-item list-group-item-action cursor-pointer bg-white";
                        item.innerHTML = `<div class="d-flex justify-content-between align-items-center"><div><div class="fw-bold">${p.TenSP}</div><small class="text-muted">${p.MaSP}</small></div><span class="badge bg-light text-dark border">${p.GiaNhap.toLocaleString()}đ</span></div>`;
                        item.onclick = function() { addToCart(p); searchInput.value = ""; searchRes.style.display = "none"; return false; }; searchRes.appendChild(item);
                    });
                } else { if(k.length > 0) searchRes.style.display = "none"; }
            }
            searchInput.addEventListener("input", performSearch); searchInput.addEventListener("focus", performSearch);
            document.addEventListener("click", function(e) { if (e.target !== searchInput && e.target.parentNode !== searchRes) { searchRes.style.display = "none"; } });
        }

        function addToCart(p) {
            var item = importCart.find(c => c.MaSP === p.MaSP);
            if(item) { item.SoLuong++; } else { importCart.push({ MaSP: p.MaSP, TenSP: p.TenSP, DVT: p.DonViTinh, SoLuong: 1, DonGia: p.GiaNhap || 0 }); }
            renderCart();
        }

        function renderCart() {
            var tbody = document.getElementById("cartBody"); var emptyState = document.getElementById("emptyState");
            if(!tbody) return; tbody.innerHTML = ""; var totalQ = 0; var totalM = 0;
            if(importCart.length === 0) { if(emptyState) emptyState.style.display = "block"; }
            else {
                if(emptyState) emptyState.style.display = "none";
                importCart.forEach((c, i) => {
                    var tt = c.SoLuong * c.DonGia; totalQ += parseInt(c.SoLuong); totalM += tt;
                    tbody.innerHTML += `<tr><td>${i+1}</td><td><div class="fw-bold text-primary">${c.TenSP}</div><small class="text-muted">${c.MaSP}</small></td><td>${c.DVT}</td><td><input type="number" class="input-compact bg-white text-center" value="${c.SoLuong}" min="1" onchange="updateCart(${i}, 'q', this.value)"></td><td><input type="number" class="input-compact bg-white text-end" value="${c.DonGia}" min="0" onchange="updateCart(${i}, 'p', this.value)"></td><td class="text-end fw-bold">${tt.toLocaleString('vi-VN')}</td><td class="text-center"><button class="btn btn-action text-danger" onclick="removeCart(${i})"><i class="fas fa-times"></i></button></td></tr>`;
                });
            }
            var lblQty = document.getElementById("lblTotalQty"); var lblMoney = document.getElementById("lblTotalMoney");
            if(lblQty) lblQty.innerText = totalQ; if(lblMoney) lblMoney.innerText = totalM.toLocaleString('vi-VN', {style:'currency', currency:'VND'});
        }

        window.updateCart = function(i, type, val) { if(type === 'q') importCart[i].SoLuong = parseInt(val)||1; if(type === 'p') importCart[i].DonGia = parseFloat(val)||0; renderCart(); };
        window.removeCart = function(i) { importCart.splice(i, 1); renderCart(); };

        function submitPhieuNhap() {
            var ncc = document.getElementById("MaNCC").value;
            if(!ncc) { Swal.fire("Lỗi", "Vui lòng chọn Nhà Cung Cấp!", "error"); return; }
            if(importCart.length === 0) { Swal.fire("Lỗi", "Giỏ hàng trống!", "error"); return; }
            Swal.fire({title: 'Đang xử lý...', didOpen: () => Swal.showLoading()});
            fetch('/Owner/SavePhieuNhap', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ MaNCC: ncc, NgayNhap: document.getElementById("NgayNhap").value, GhiChu: document.getElementById("GhiChu").value, ChiTiet: importCart })
            }).then(res => res.json()).then(data => {
                if(data.success) { Swal.fire("Thành công", "Nhập kho thành công!", "success").then(() => window.location.reload()); }
                else { Swal.fire("Lỗi", data.msg, "error"); }
            }).catch(() => Swal.fire("Lỗi", "Mất kết nối", "error"));
        }

        var html5QrcodeScanner = null;
        function openScannerModal() {
               new bootstrap.Modal(document.getElementById('scannerModal')).show();
               if (!html5QrcodeScanner) {
                   html5QrcodeScanner = new Html5Qrcode("reader");
               }

               const config = {
                   fps: 10,
                   qrbox: { width: 250, height: 120 },
                   disableFlip: false,
                   // VŨ KHÍ TỐI THƯỢNG: Ép camera CHỈ ĐƯỢC ĐỌC MÃ EAN-13 VÀ CODE-128.
                   // Thư viện sẽ tự dùng toán học (Checksum) để kiểm tra, ngăn chặn 100% sự ảo giác.
                   formatsToSupport: [
                       Html5QrcodeSupportedFormats.EAN_13,
                       Html5QrcodeSupportedFormats.CODE_128
                   ]
               };

               html5QrcodeScanner.start({ facingMode: "user" }, config, onScanSuccess)
               .catch(err => {
                   Swal.fire("Lỗi Camera", "Không thể bật camera.", "error");
                   bootstrap.Modal.getInstance(document.getElementById('scannerModal')).hide();
               });
           }

           function onScanSuccess(decodedText, decodedResult) {
               // Quét trúng là tắt camera ngay và luôn
               stopScanner();
               var modal = bootstrap.Modal.getInstance(document.getElementById('scannerModal'));
               if(modal) modal.hide();

               var audio = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');
               audio.play().catch(e => {});

               document.getElementById("scanBarcode").value = decodedText;

               var p = allProducts.find(x => x.MaVach === decodedText || x.MaSP === decodedText);
               if(p) {
                   addToCart(p);
                   document.getElementById("scanBarcode").value = "";
                   Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã quét: ' + p.TenSP, showConfirmButton: false, timer: 1500 });
               } else {
                   Swal.fire({
                       title: 'Mã chưa tồn tại!',
                       text: `Hệ thống ghi nhận mã [${decodedText}]. Tạo sản phẩm mới?`,
                       icon: 'question',
                       showCancelButton: true,
                       confirmButtonColor: '#3085d6',
                       cancelButtonColor: '#d33',
                       confirmButtonText: 'Đồng ý Tạo'
                   }).then((result) => {
                       if (result.isConfirmed) {
                           openProductModal();
                           document.getElementById("new_MaVach").value = decodedText;
                           document.getElementById("scanBarcode").value = "";
                       }
                   });
               }
           }
        function stopScanner() { if (html5QrcodeScanner && html5QrcodeScanner.isScanning) { html5QrcodeScanner.stop().catch(err => {}); } }

