          // 3. Tự động gọi API sinh mã (SON-NP-0016) khi nhập Nhóm và NCC
          function autoGenerateSKU() {
              var nhom = document.getElementById("new_NhomHang").value;
              var ncc = document.getElementById("new_MaNCC_SP").value; // Lấy tên NCC
              if(nhom && ncc) {
                  // Đổ API C# để lấy chữ viết tắt
                  fetch(`/Owner/GenerateSKU?tenNhom=${encodeURIComponent(nhom)}&tenNCC=${encodeURIComponent(ncc)}`)
                  .then(res => res.json())
                  .then(data => {
                      if(data.success) {
                          document.getElementById("new_MaSP").value = data.maSP;
                          generateLotQR(); // Gọi thử cập nhật QR nếu đang có gõ số lô
                      }
                  });
              }
