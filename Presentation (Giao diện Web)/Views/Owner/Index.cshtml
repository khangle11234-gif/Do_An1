                                <tr><th>Mã SP</th><th class="text-start">Tên Sản Phẩm</th><th>Mã Vạch</th><th>ĐVT</th><th>Tồn Kho</th><th>Giá Nhập</th><th class="bg-warning text-dark">Giá Bán</th><th>Trạng Thái</th><th>Thao tác</th></tr>
