                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>

    <script>
        // ============================================================
        // === 1. LOGIC CHUNG VÀ CHUYỂN TAB ===
        // ============================================================
        document.addEventListener("DOMContentLoaded", function () {
            var successMessage = '@(TempData["Message"] ?? "")';
            var errorMessage = '@(TempData["Error"] ?? "")';
            if (successMessage || errorMessage) {
                if (successMessage.includes("sản phẩm") || errorMessage.includes("sản phẩm")) {
                    new bootstrap.Tab(document.querySelector('a[href="#tab-products"]')).show();
                } else {
                    new bootstrap.Tab(document.querySelector('#link-tab-employees')).show();
                }
            } else {
                var activeTab = localStorage.getItem('ownerActiveTab');
                if (activeTab) { new bootstrap.Tab(document.querySelector('a[href="' + activeTab + '"]')).show(); }
            }
            var tabLinks = document.querySelectorAll('a[data-bs-toggle="pill"]');
            tabLinks.forEach(function (tab) {
                tab.addEventListener('shown.bs.tab', function (e) {
                    localStorage.setItem('ownerActiveTab', e.target.getAttribute('href'));
                });
            });

            renderPosProducts();

            var scanModalEl = document.getElementById('scannerModal');
            if(scanModalEl) {
                scanModalEl.addEventListener('hidden.bs.modal', function () {
                    stopScanner();
                });
            }
        });

        var allProducts = @Html.Raw(productsJson);

        // ============================================================
        // === 2. LOGIC BÁN HÀNG (POS) ===
        // ============================================================
        var posCart = [];

        function renderPosProducts() {
            var grid = document.getElementById("posProductGrid");
            if (!grid) return;

            var keyword = document.getElementById("searchPosProduct").value.toLowerCase();
            grid.innerHTML = "";

            var filtered = allProducts.filter(p =>
                p.TrangThai === true && p.SoLuongTon > 0 &&
                (p.TenSP.toLowerCase().includes(keyword) || p.MaSP.toLowerCase().includes(keyword))
            );

            if(filtered.length === 0) {
                grid.innerHTML = `<div class="col-12 py-5 text-center text-muted"><i class="fas fa-box-open fa-3x mb-3 opacity-25"></i><br/>Không tìm thấy sản phẩm hoặc đã hết hàng.</div>`;
                return;
            }

            filtered.forEach(p => {
                var card = `
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 pos-item-card position-relative" onclick="addToPosCart('${p.MaSP}')">
                            <div class="card-body p-3 text-center">
                                <span class="badge bg-success position-absolute top-0 end-0 m-2">Tồn: ${p.SoLuongTon}</span>
                                <div class="mb-2"><i class="fas fa-box fa-3x text-info opacity-75"></i></div>
                                <h6 class="fw-bold mb-1 text-truncate" title="${p.TenSP}">${p.TenSP}</h6>
                                <p class="text-danger fw-bold mb-0 fs-6">${(p.GiaBan).toLocaleString()} ₫</p>
                            </div>
                        </div>
                    </div>`;
                grid.innerHTML += card;
            });
        }

        function filterPosProducts() { renderPosProducts(); }

        function addToPosCart(maSP) {
            var p = allProducts.find(x => x.MaSP === maSP);
            if(!p) return;

            var item = posCart.find(x => x.MaSP === maSP);
            if(item) {
                if(item.SoLuong + 1 > p.SoLuongTon) {
                    Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Vượt quá tồn kho!', showConfirmButton: false, timer: 2000});
                    return;
                }
                item.SoLuong++;
            } else {
                posCart.push({ MaSP: p.MaSP, TenSP: p.TenSP, GiaBan: p.GiaBan, SoLuong: 1, TonKho: p.SoLuongTon });
            }

            Swal.fire({toast:true, position: 'top-end', icon: 'success', title: 'Đã thêm ' + p.TenSP, showConfirmButton: false, timer: 1000});
            updatePosUI();
        }

        function updatePosUI() {
            var tbody = document.getElementById("posCartTable");
            tbody.innerHTML = "";
            var totalQ = 0; var totalM = 0;

            if(posCart.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="fas fa-cart-arrow-down fa-3x mb-2 opacity-25"></i><br>Chưa có sản phẩm nào.</td></tr>`;
            } else {
                posCart.forEach((c, index) => {
                    totalQ += parseInt(c.SoLuong);
                    totalM += (c.SoLuong * c.GiaBan);

                    tbody.innerHTML += `
                        <tr class="text-center">
                            <td class="text-start ps-3">
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">${c.TenSP}</div>
                                <small class="text-muted">${c.MaSP}</small>
                            </td>
                            <td>
                                <div class="d-flex align-items-center justify-content-center">
                                    <button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${index}, -1)"><i class="fas fa-minus" style="font-size:10px;"></i></button>
                                    <input type="number" class="form-control form-control-sm text-center mx-1 fw-bold border-0 bg-transparent pos-qty-input" value="${c.SoLuong}" style="width: 40px;" readonly>
                                    <button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${index}, 1)"><i class="fas fa-plus" style="font-size:10px;"></i></button>
                                </div>
                            </td>
                            <td class="fw-bold text-danger">${(c.GiaBan * c.SoLuong).toLocaleString()} ₫</td>
                            <td><button class="btn btn-sm text-danger" onclick="removePosItem(${index})"><i class="fas fa-times"></i></button></td>
                        </tr>`;
                });
            }

            document.getElementById("posTotalQuantity").innerText = totalQ;
            document.getElementById("posTotalAmount").innerText = totalM.toLocaleString() + " ₫";
        }

        function changePosQty(index, amount) {
            var item = posCart[index];
            var newQty = item.SoLuong + amount;

            if(newQty <= 0) { removePosItem(index); return; }
            if(newQty > item.TonKho) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Trong kho chỉ còn ' + item.TonKho + ' SP!', showConfirmButton: false, timer: 2000}); return; }

            item.SoLuong = newQty;
            updatePosUI();
        }

        function removePosItem(index) { posCart.splice(index, 1); updatePosUI(); }

        function clearPosCart() {
            if(posCart.length === 0) return;
            Swal.fire({
                title: 'Hủy đơn hàng?', text: "Xóa toàn bộ giỏ hàng?", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#d33', cancelButtonColor: '#aaa', confirmButtonText: 'Đồng ý Hủy'
            }).then((result) => { if (result.isConfirmed) { posCart = []; updatePosUI(); } });
        }

        // ============================================================
        // === [MỚI] LOGIC TẠO QR ĐỘNG & THANH TOÁN ===
        // ============================================================
        function openPaymentModal() {
            if(posCart.length === 0) { Swal.fire("Lỗi", "Giỏ hàng đang trống, không thể thanh toán!", "error"); return; }

            var totalM = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);
            document.getElementById('qrTotalAmount').innerText = totalM.toLocaleString() + ' ₫';

            var savedBank = localStorage.getItem('posBank');
            var savedAcc = localStorage.getItem('posAcc');
            var savedName = localStorage.getItem('posName');
            if(savedBank) document.getElementById('qrBank').value = savedBank;
            if(savedAcc) document.getElementById('qrAccount').value = savedAcc;
            if(savedName) document.getElementById('qrName').value = savedName;

            generateQR();
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }

        function generateQR() {
            var bank = document.getElementById('qrBank').value;
            var acc = document.getElementById('qrAccount').value;
            var name = document.getElementById('qrName').value;
            var note = document.getElementById("posNote").value || "Thanh toan mua hang";
            var totalM = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);

            localStorage.setItem('posBank', bank);
            localStorage.setItem('posAcc', acc);
            localStorage.setItem('posName', name);

            if(bank && acc && totalM > 0) {
                var qrUrl = `https://img.vietqr.io/image/${bank}-${acc}-compact2.png?amount=${totalM}&addInfo=${encodeURIComponent(note)}&accountName=${encodeURIComponent(name)}`;
                document.getElementById('qrImage').src = qrUrl;
                document.getElementById('qrImageContainer').style.display = 'block';
            } else {
                document.getElementById('qrImageContainer').style.display = 'none';
            }
        }

        function confirmPaymentAndSave() {
            bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
            processCheckout();
        }

        function processCheckout() {
            Swal.fire({ title: 'Đang xử lý thanh toán...', didOpen: () => Swal.showLoading() });

            var payload = {
                GhiChu: document.getElementById("posNote").value,
                CartItems: posCart.map(c => ({ MaSP: c.MaSP, SoLuong: c.SoLuong, GiaBan: c.GiaBan }))
            };

            fetch('/Owner/ProcessPosCheckout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire({ title: "Thanh toán thành công!", text: "Mã hóa đơn: " + data.maHD, icon: "success" }).then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire("Lỗi thanh toán", data.msg, "error");
                }
            })
            .catch(err => { Swal.fire("Lỗi", "Không thể kết nối đến máy chủ", "error"); });
        }

        // ============================================================
        // === [MỚI] XEM LỊCH SỬ HÓA ĐƠN ===
        // ============================================================
          function openInvoiceHistoryModal() {
              new bootstrap.Modal(document.getElementById('invoiceHistoryModal')).show();
              document.getElementById('invoiceDetailArea').innerHTML = `<div class="text-center text-muted mt-5"><i class="fas fa-receipt fa-4x mb-3 opacity-25"></i><h5>Chọn một hóa đơn bên trái để xem chi tiết</h5></div>`;

              fetch('/Owner/GetInvoicesAPI')
              .then(res => res.json())
              .then(data => {
                  var list = document.getElementById('invoiceList');
                  list.innerHTML = "";

                  if(data.success) {
                      if(data.data.length > 0) {
                          data.data.forEach(hd => {
                              var ma = hd.maHD || hd.MaHD;
                              var tt = hd.tongTien || hd.TongTien || 0;
                              var date = hd.ngayTao || hd.NgayTao || "";
                              list.innerHTML += `<button class="list-group-item list-group-item-action p-3" onclick="viewInvoiceDetails('${ma}', ${tt})"><div class="d-flex justify-content-between align-items-center mb-1"><strong class="text-info">${ma}</strong><span class="badge bg-danger rounded-pill">${tt.toLocaleString()} ₫</span></div><small class="text-muted"><i class="far fa-clock me-1"></i> Lập: ${date}</small></button>`;
                          });
                      } else {
                          list.innerHTML = `<div class="p-4 text-center text-muted">Chưa có hóa đơn nào!</div>`;
                      }
                  } else {
                      list.innerHTML = `<div class="p-4 text-center text-danger fw-bold"><i class="fas fa-exclamation-triangle fa-2x mb-2"></i><br/>${data.msg}</div>`;
                  }
              })
              .catch(() => {
                  document.getElementById('invoiceList').innerHTML = `<div class="p-4 text-center text-danger">Mất kết nối máy chủ!</div>`;
              });
          }

        function viewInvoiceDetails(maHD, tongTien) {
            var area = document.getElementById('invoiceDetailArea'); area.innerHTML = `<div class="text-center mt-5"><div class="spinner-border text-info"></div><p class="mt-2 text-muted">Đang tải chi tiết...</p></div>`;
            fetch('/Owner/GetInvoiceDetailsAPI?maHD=' + maHD).then(res => res.json()).then(data => {
                if(data.success) {
                    var html = `<div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom"><h4 class="fw-bold mb-0 text-info">MÃ HĐ: ${maHD}</h4><button class="btn btn-outline-secondary btn-sm shadow-sm" onclick="window.print()"><i class="fas fa-print me-1"></i> In lại HĐ</button></div><div class="table-responsive"><table class="table table-bordered table-striped text-center align-middle"><thead class="table-light"><tr><th>Mã SP</th><th class="text-start">Tên SP</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead><tbody>`;
                    data.data.forEach(c => { var mSP = c.maSP || c.MaSP; var tSP = c.tenSP || c.TenSP; var sl = c.soLuong || c.SoLuong; var gb = c.giaBan || c.GiaBan || 0; var tt = c.thanhTien || c.ThanhTien || 0;
                        html += `<tr><td class="text-muted fw-bold">${mSP}</td><td class="text-start fw-bold text-dark">${tSP}</td><td class="fs-6 fw-bold">${sl}</td><td>${gb.toLocaleString()} ₫</td><td class="text-danger fw-bold">${tt.toLocaleString()} ₫</td></tr>`;
                    });
                    html += `</tbody></table></div><div class="text-end mt-4 p-3 bg-light rounded"><span class="fs-5 text-muted">Tổng cộng:</span><span class="fs-3 fw-bold text-danger ms-3">${tongTien.toLocaleString()} ₫</span></div>`;
                    area.innerHTML = html;
                } else { area.innerHTML = `<div class="text-center mt-5 text-danger">${data.msg}</div>`; }
            });
        }

        // ============================================================
        // === 3. LOGIC NHẬP HÀNG & QUÉT CAMERA ===
        // ============================================================
        var cart = [];
        var inputBarcode = document.getElementById("scanBarcode");
        if(inputBarcode){
            inputBarcode.addEventListener("keyup", function(e) {
                if (e.key === "Enter") {
                    var code = this.value.trim();
                    var p = allProducts.find(x => x.MaVach === code);
                    if(p) { addToCart(p); this.value = ""; } else { Swal.fire("Lỗi", "Không tìm thấy mã vạch!", "error"); }
                }
            });
        }

        var searchInput = document.getElementById("searchProduct");
        var searchRes = document.getElementById("searchResults");

        if(searchInput && searchRes){
            function performSearch() {
                var k = searchInput.value.toLowerCase();
                searchRes.innerHTML = "";
                var sourceData = [...allProducts].reverse();
                var matches = k.length < 1 ? sourceData : sourceData.filter(p => p.TenSP.toLowerCase().includes(k) || p.MaSP.toLowerCase().includes(k));

                if(matches.length > 0) {
                    searchRes.style.display = "block";
                    matches.slice(0, 6).forEach(p => {
                        var item = document.createElement("a");
                        item.className = "list-group-item list-group-item-action cursor-pointer";
                        item.innerHTML = `<div class="d-flex justify-content-between align-items-center"><div><div class="fw-bold">${p.TenSP}</div><small class="text-muted">${p.MaSP}</small></div><span class="badge bg-light text-dark border">${p.GiaNhap.toLocaleString()}đ</span></div>`;
                        item.onclick = function() { addToCart(p); searchInput.value = ""; searchRes.style.display = "none"; return false; };
                        searchRes.appendChild(item);
                    });
                } else { if(k.length > 0) searchRes.style.display = "none"; }
            }
            searchInput.addEventListener("input", performSearch);
            searchInput.addEventListener("focus", performSearch);
            document.addEventListener("click", function(e) { if (e.target !== searchInput && e.target.parentNode !== searchRes) { searchRes.style.display = "none"; } });
        }

        function addToCart(p) {
            var item = cart.find(c => c.MaSP === p.MaSP);
            if(item) { item.SoLuong++; } else { cart.push({ MaSP: p.MaSP, TenSP: p.TenSP, DVT: p.DonViTinh, SoLuong: 1, DonGia: p.GiaNhap || 0 }); }
            renderCart();
        }

        function renderCart() {
            var tbody = document.getElementById("cartBody"); var emptyState = document.getElementById("emptyState");
            if(!tbody) return; tbody.innerHTML = ""; var totalQ = 0; var totalM = 0;
            if(cart.length === 0) { if(emptyState) emptyState.style.display = "block"; }
            else {
                if(emptyState) emptyState.style.display = "none";
                cart.forEach((c, i) => {
                    var tt = c.SoLuong * c.DonGia; totalQ += parseInt(c.SoLuong); totalM += tt;
                    tbody.innerHTML += `<tr><td>${i+1}</td><td><div class="fw-bold text-primary product-link" onclick="viewProductDetail('${c.MaSP}')" title="Xem chi tiết">${c.TenSP}</div><small class="text-muted">${c.MaSP}</small></td><td>${c.DVT}</td><td><input type="number" class="input-compact text-center" value="${c.SoLuong}" min="1" onchange="updateCart(${i}, 'q', this.value)"></td><td><input type="number" class="input-compact text-end" value="${c.DonGia}" min="0" onchange="updateCart(${i}, 'p', this.value)"></td><td class="text-end fw-bold">${tt.toLocaleString('vi-VN')}</td><td class="text-center"><button class="btn btn-action text-danger" onclick="removeCart(${i})"><i class="fas fa-times"></i></button></td></tr>`;
                });
            }
            var lblQty = document.getElementById("lblTotalQty"); var lblMoney = document.getElementById("lblTotalMoney");
            if(lblQty) lblQty.innerText = totalQ; if(lblMoney) lblMoney.innerText = totalM.toLocaleString('vi-VN', {style:'currency', currency:'VND'});
        }

        window.updateCart = function(i, type, val) { if(type === 'q') cart[i].SoLuong = parseInt(val)||1; if(type === 'p') cart[i].DonGia = parseFloat(val)||0; renderCart(); };
        window.removeCart = function(i) { cart.splice(i, 1); renderCart(); };
        window.viewProductDetail = function(maSP) {
            var p = allProducts.find(x => x.MaSP === maSP);
            if(p) { document.getElementById('view_MaSP').value = p.MaSP; document.getElementById('view_MaVach').value = p.MaVach || 'Chưa có'; document.getElementById('view_TenSP').value = p.TenSP; document.getElementById('view_DVT').value = p.DonViTinh; document.getElementById('view_GiaVon').value = p.GiaNhap ? p.GiaNhap.toLocaleString() + ' ₫' : '0 ₫'; new bootstrap.Modal(document.getElementById('modalViewProduct')).show(); }
        };

        function submitPhieuNhap() {
            var ncc = document.getElementById("MaNCC").value;
            if(!ncc) { Swal.fire("Lỗi", "Vui lòng chọn Nhà Cung Cấp!", "error"); return; }
            if(cart.length === 0) { Swal.fire("Lỗi", "Giỏ hàng trống!", "error"); return; }

            Swal.fire({title: 'Đang xử lý...', didOpen: () => Swal.showLoading()});

            fetch('/Owner/SavePhieuNhap', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    MaNCC: ncc,
                    NgayNhap: document.getElementById("NgayNhap").value,
                    GhiChu: document.getElementById("GhiChu").value,
                    ChiTiet: cart
                })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire("Thành công", "Nhập kho thành công!", "success").then(() => {
                        window.location.reload();
                    });
                }
                else {
                    Swal.fire("Lỗi", data.msg, "error");
                }
            })
            .catch(() => Swal.fire("Lỗi", "Mất kết nối", "error"));
        }

        var html5QrcodeScanner = null;

        function openScannerModal() {
            new bootstrap.Modal(document.getElementById('scannerModal')).show();
            if (!html5QrcodeScanner) {
                html5QrcodeScanner = new Html5Qrcode("reader");
            }

            const config = { fps: 10, qrbox: { width: 250, height: 100 } };

            html5QrcodeScanner.start({ facingMode: "environment" }, config, onScanSuccess)
            .catch(err => {
                Swal.fire("Lỗi Camera", "Không thể bật camera. Hãy kiểm tra xem bạn đã cấp quyền cho trình duyệt chưa! ", "error");
                bootstrap.Modal.getInstance(document.getElementById('scannerModal')).hide();
            });
        }

        function onScanSuccess(decodedText, decodedResult) {
            stopScanner();
            var modal = bootstrap.Modal.getInstance(document.getElementById('scannerModal'));
            if(modal) modal.hide();

            var audio = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');
            audio.play().catch(e => {});

            document.getElementById("scanBarcode").value = decodedText;

            var p = allProducts.find(x => x.MaVach === decodedText);
            if(p) {
                addToCart(p);
                document.getElementById("scanBarcode").value = "";
                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã quét: ' + p.TenSP, showConfirmButton: false, timer: 1500 });
            } else {
                Swal.fire("Lỗi", "Mã vạch [" + decodedText + "] chưa có trong hệ thống!", "error");
            }
        }

        function stopScanner() {
            if (html5QrcodeScanner && html5QrcodeScanner.isScanning) {
                html5QrcodeScanner.stop().catch(err => console.log("Lỗi dừng camera", err));
            }
        }

        // ============================================================
        // === 4. LOGIC QUẢN LÝ SẢN PHẨM & CÁC MODAL KHÁC ===
        // ============================================================
        function toggleProductStatus(maSP, checkboxObj) {
            fetch('/Owner/ToggleProductStatusAPI', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ MaSP: maSP }) })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    var textObj = document.getElementById("status_text_" + maSP);
                    if(data.newStatus) { textObj.innerText = "Đang bán"; textObj.className = "text-success fw-bold mt-1 d-block"; }
                    else { textObj.innerText = "Ngừng bán"; textObj.className = "text-danger fw-bold mt-1 d-block"; }
                    Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã lưu trạng thái', showConfirmButton: false, timer: 1500 });
                } else { checkboxObj.checked = !checkboxObj.checked; Swal.fire("Lỗi", "Không thể đổi trạng thái", "error"); }
            }).catch(() => { checkboxObj.checked = !checkboxObj.checked; Swal.fire("Lỗi mạng", "Không thể kết nối đến máy chủ", "error"); });
        }

        function submitEditProduct(event, maSP) {
            event.preventDefault();
            var form = document.getElementById('formEdit_' + maSP);
            var formData = new FormData(form);
            var payload = { MaSP: maSP, TenSP: formData.get("TenSP"), DonViTinh: formData.get("DonViTinh"), MaVach: formData.get("MaVach"), GiaBan: parseFloat(formData.get("GiaBan")) || 0, ThoiGianBaoHanh: parseInt(formData.get("ThoiGianBaoHanh")) || 0, TrangThai: formData.get("TrangThai") === "true" };

            fetch('/Owner/UpdateProductAPI', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('editSP_' + maSP)).hide();
                    var priceTd = document.getElementById('price_text_' + maSP); if(priceTd) priceTd.innerText = data.giaBanMoi;
                    var nameTd = document.getElementById('name_text_' + maSP); if(nameTd) nameTd.innerText = data.tenSPMoi;
                    var switchObj = document.getElementById('switch_' + maSP);
                    if(switchObj) {
                        switchObj.checked = data.trangThaiMoi;
                        var textObj = document.getElementById("status_text_" + maSP);
                        if(data.trangThaiMoi) { textObj.innerText = "Đang bán"; textObj.className = "text-success fw-bold mt-1 d-block"; }
                        else { textObj.innerText = "Ngừng bán"; textObj.className = "text-danger fw-bold mt-1 d-block"; }
                    }
                    Swal.fire({ icon: 'success', title: 'Hoàn tất', text: "Sửa thông tin thành công!", timer: 1500, showConfirmButton: false });
                } else { Swal.fire('Lỗi', data.msg, 'error'); }
            }).catch(() => Swal.fire("Lỗi mạng", "Không thể kết nối đến máy chủ", "error"));
        }

        function openSupplierModal() { document.getElementById('new_TenNCC').value=''; new bootstrap.Modal(document.getElementById('modalAddSupplier')).show(); }
        function saveNewSupplier() {
            var ten = document.getElementById('new_TenNCC').value; var sdt = document.getElementById('new_SDT').value; var diachi = document.getElementById('new_DiaChi').value; var ghichu = document.getElementById('new_GhiChu').value;
            if(!ten) { alert("Vui lòng nhập tên NCC"); return; }
            fetch('/NhapHang/CreateQuickSupplier', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ TenNCC: ten, SDT: sdt, DiaChi: diachi, GhiChu: ghichu }) })
            .then(res => res.json()).then(res => {
                if(res.success) { var select = document.getElementById("MaNCC"); var option = document.createElement("option"); option.value = res.data.maNCC; option.text = res.data.tenNCC; option.selected = true; select.add(option); bootstrap.Modal.getInstance(document.getElementById('modalAddSupplier')).hide(); Swal.fire("Thành công", "Đã thêm NCC: " + ten, "success"); }
                else { Swal.fire("Lỗi", res.msg, "error"); }
            });
        }
        function openProductModal() { document.getElementById('new_MaSP').value=''; document.getElementById('new_TenSP').value=''; new bootstrap.Modal(document.getElementById('modalAddProduct')).show(); }
        function saveNewProduct() {
             var ma = document.getElementById('new_MaSP').value;
             var ten = document.getElementById('new_TenSP').value;
             var mv = document.getElementById('new_MaVach').value;
             var dvt = document.getElementById('new_DVT').value;
             var giaNhap = parseFloat(document.getElementById('new_GiaNhap').value) || 0;
             var giaBan = parseFloat(document.getElementById('new_GiaBan').value) || 0;
             var baoHanh = parseInt(document.getElementById('new_BaoHanh').value) || 0;

             if(!ma || !ten) {
                 Swal.fire("Thiếu thông tin", "Vui lòng nhập Mã và Tên sản phẩm", "warning");
                 return;
             }

             fetch('/Owner/CreateQuickProductAPI', {
                 method: 'POST',
                 headers: { 'Content-Type': 'application/json' },
                 body: JSON.stringify({
                     MaSP: ma,
                     TenSP: ten,
                     MaVach: mv,
                     DonViTinh: dvt,
                     GiaNhap: giaNhap,
                     DonGiaNhap: giaNhap,
                     GiaBan: giaBan,
                     ThoiGianBaoHanh: baoHanh
                 })
             })
             .then(res => res.json())
             .then(res => {
                 if(res.success) {
                     bootstrap.Modal.getInstance(document.getElementById('modalAddProduct')).hide();

                     var newP = {
                         MaSP: ma, TenSP: ten, MaVach: mv, DonViTinh: dvt,
                         GiaNhap: giaNhap, GiaBan: giaBan, SoLuongTon: 0, TrangThai: true
                     };
                     allProducts.push(newP);
                     addToCart(newP);

                     Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Đã tạo vỏ SP mới', showConfirmButton: false, timer: 1500 });
                 }
                 else {
                     Swal.fire("Lỗi", res.msg, "error");
                 }
             })
             .catch(() => Swal.fire("Lỗi", "Mất kết nối máy chủ", "error"));
         }

        // =========================================================
        // === LOGIC QUẢN LÝ NHÂN VIÊN ===
        // =========================================================
        function openAddModal() {
            document.getElementById('userForm').reset();
            document.getElementById('modal_MaND').value = '';
            document.getElementById('modalTitle').innerText = "THÊM NHÂN VIÊN MỚI";
            document.getElementById('modal_TenDangNhap').readOnly = false;

            var switchBtn = document.getElementById('modal_TrangThai');
            var hiddenInput = document.getElementById('real_HienThi_Value');
            switchBtn.checked = true;
            hiddenInput.value = "true";
            switchBtn.onchange = function() { hiddenInput.value = this.checked ? "true" : "false"; };

            var roleSelect = document.getElementById('modal_VaiTro');
            if(roleSelect) autoSelectPermissionModal(roleSelect.value);

            var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('editUserModal'));
            myModal.show();
        }

        function openEditModal(id, user, name, role, quyen, email, status) {
            document.getElementById('userForm').reset();
            document.getElementById('modalTitle').innerText = "CẬP NHẬT NHÂN VIÊN";
            document.getElementById('modal_MaND').value = id;
            document.getElementById('modal_TenDangNhap').value = user;
            document.getElementById('modal_TenDangNhap').readOnly = true;
            document.getElementById('modal_HoTen').value = name;
            document.getElementById('modal_VaiTro').value = role;
            document.getElementById('modal_Email').value = email;

            var switchBtn = document.getElementById('modal_TrangThai');
            var hiddenInput = document.getElementById('real_HienThi_Value');
            switchBtn.checked = status;
            hiddenInput.value = status ? "true" : "false";
            switchBtn.onchange = function() { hiddenInput.value = this.checked ? "true" : "false"; };

            autoSelectPermissionModal(role);

            var myModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('editUserModal'));
            myModal.show();
        }

        function submitUserForm(event) {
            event.preventDefault();
            var fd = new FormData(document.getElementById('userForm'));
            var payload = {
                MaND: fd.get("MaND"),
                TenDangNhap: fd.get("TenDangNhap"),
                HoTen: fd.get("HoTen"),
                Email: fd.get("Email"),
                MatKhau: fd.get("MatKhau"),
                VaiTro: fd.get("VaiTro"),
                MaNhomQuyen: fd.get("MaNhomQuyen"),
                TrangThai: fd.get("HienThi") === "true"
            };

            fetch('/Owner/SaveUserAPI', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                    Swal.fire({icon: 'success', title: 'Thành công!', showConfirmButton: false, timer: 1500}).then(() => location.reload());
                } else {
                    Swal.fire("Lỗi", data.msg, "error");
                }
            }).catch(() => Swal.fire("Lỗi mạng", "Không kết nối được server", "error"));
        }

        function openDeleteModal(id, name) {
            document.getElementById('deleteUserId').value = id;
            document.getElementById('deleteUserName').innerText = name;
            new bootstrap.Modal(document.getElementById('deleteUserModal')).show();
        }

        function submitDeleteUser() {
            var id = document.getElementById('deleteUserId').value;
            fetch('/Owner/DeleteUserAPI', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ MaND: id })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('deleteUserModal')).hide();
                    Swal.fire('Đã xóa', '', 'success').then(()=>location.reload());
                }
                else Swal.fire('Lỗi', data.msg, 'error');
            });
        }

        function autoSelectPermissionModal(role) {
            var map = { 'Sale': 'STAFF_SALE', 'Kho': 'STAFF_KHO', 'Owner': 'OWNER_FULL' };
            if(map[role]) {
                var radio = document.getElementById('modal_radio_' + map[role]);
                if(radio) radio.checked = true;
            }
        }

        function openKiemKeModal(maSP, tenSP, tonHeThong) {
            document.getElementById('kk_MaSP').value = maSP;
            document.getElementById('kk_TenSP').innerText = tenSP;
            document.getElementById('kk_TonHeThong').innerText = tonHeThong;
            document.getElementById('kk_TonThucTe').value = tonHeThong;
            document.getElementById('kk_LyDo').value = '';
            calcChenhLech();
            new bootstrap.Modal(document.getElementById('kiemKeModal')).show();
        }

        function calcChenhLech() {
            var heThong = parseInt(document.getElementById('kk_TonHeThong').innerText) || 0;
            var thucTe = parseInt(document.getElementById('kk_TonThucTe').value) || 0;
            var diff = thucTe - heThong;

            var el = document.getElementById('kk_ChenhLech');
            if (diff > 0) {
                el.value = "+" + diff + " (Đang dư hàng)";
                el.className = "form-control bg-success text-white fw-bold";
            } else if (diff < 0) {
                el.value = diff + " (Đang thiếu hàng)";
                el.className = "form-control bg-danger text-white fw-bold";
            } else {
                el.value = "0 (Khớp hoàn toàn)";
                el.className = "form-control bg-light text-muted fw-bold";
            }
        }

        function submitKiemKe() {
            var maSP = document.getElementById('kk_MaSP').value;
            var thucTe = parseInt(document.getElementById('kk_TonThucTe').value);
            var lyDo = document.getElementById('kk_LyDo').value;

            if (isNaN(thucTe) || thucTe < 0) {
                Swal.fire("Lỗi", "Số lượng thực tế không hợp lệ", "error");
                return;
            }

            Swal.fire({title: 'Đang cập nhật kho...', didOpen: () => Swal.showLoading()});

            fetch('/Owner/KiemKeKhoAPI', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ MaSP: maSP, TonThucTe: thucTe, GhiChu: lyDo })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('kiemKeModal')).hide();
                    Swal.fire({icon: 'success', title: 'Hoàn tất', text: 'Đã cân bằng kho thành công!', timer: 1500, showConfirmButton: false})
                    .then(() => {
                        window.location.reload();
                    });
                } else {
                    Swal.fire("Lỗi", data.msg, "error");
                }
            }).catch(() => Swal.fire("Lỗi mạng", "Không kết nối được server", "error"));
        }

        function submitEditSupplier(event, maNCC) {
            event.preventDefault();
            var form = document.getElementById('formEditNCC_' + maNCC);
            var fd = new FormData(form);

            fetch('/Owner/UpdateSupplierAPI', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    MaNCC: maNCC,
                    TenNCC: fd.get("TenNCC"),
                    SDT: fd.get("SDT"),
                    DiaChi: fd.get("DiaChi"),
                    GhiChu: fd.get("GhiChu")
                })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire({icon:'success', title:'Cập nhật thành công', showConfirmButton: false, timer:1500})
                    .then(() => location.reload());
                } else {
                    Swal.fire('Lỗi', data.msg, 'error');
                }
            });
        }

        function deleteSupplier(maNCC) {
            Swal.fire({
                title: 'Xóa Nhà cung cấp?',
                text: "Hành động này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa luôn',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Owner/DeleteSupplierAPI', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ MaNCC: maNCC })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success) {
                            Swal.fire('Đã xóa!', '', 'success').then(()=>location.reload());
                        } else {
                            Swal.fire('Lỗi', data.msg, 'error');
                        }
                    });
                }
            });
        }

        // --- [MỚI] LOGIC CLICK BIỂU ĐỒ (CÓ DANH SÁCH SP) ---
        function showMonthDetail(month) {
            Swal.fire({ title: 'Đang tải dữ liệu...', didOpen: () => Swal.showLoading() });

            fetch('/Owner/GetMonthlyStatsAPI?month=' + month)
            .then(res => res.json())
            .then(data => {
                Swal.close();
                if(data.success) {
                    // 1. Gắn số liệu tổng
                    document.getElementById('md_Thang').innerText = data.thang;
                    document.getElementById('md_DoanhThu').innerText = data.doanhThu.toLocaleString() + " ₫";
                    document.getElementById('md_LoiNhuan').innerText = data.loiNhuan.toLocaleString() + " ₫";
                    document.getElementById('md_SoHD').innerText = data.soHoaDon;
                    document.getElementById('md_SoSP').innerText = data.tongSpBan;

                    // 2. Vẽ danh sách sản phẩm
                    var tbody = document.getElementById('md_ProductList');
                    tbody.innerHTML = "";
                    if(data.soldItems && data.soldItems.length > 0) {
                        data.soldItems.forEach(item => {
                            // Chống lỗi viết hoa viết thường JSON của C#
                            var ten = item.tenSP || item.TenSP;
                            var ma = item.maSP || item.MaSP;
                            var sl = item.soLuong || item.SoLuong;
                            var dt = item.doanhThu || item.DoanhThu;

                            tbody.innerHTML += `
                                <tr>
                                    <td class="text-start ps-3">
                                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">${ten}</div>
                                        <small class="text-muted">${ma}</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info text-dark bg-opacity-10 fs-6 border border-info border-opacity-25">${sl}</span>
                                    </td>
                                    <td class="text-end fw-bold text-success pe-3">${dt.toLocaleString()} ₫</td>
                                </tr>
                            `;
                        });
                    } else {
                        tbody.innerHTML = `<tr><td colspan="3" class="text-center text-muted py-4"><i class="fas fa-box-open fa-2x mb-2 opacity-25"></i><br>Không có sản phẩm nào được bán trong tháng này.</td></tr>`;
                    }

                    // 3. Mở bảng
                    new bootstrap.Modal(document.getElementById('monthDetailModal')).show();
                } else {
                    Swal.fire("Lỗi", data.msg, "error");
                }
            })
            .catch(() => Swal.fire("Lỗi mạng", "Không kết nối được server", "error"));
        }
    </script>
