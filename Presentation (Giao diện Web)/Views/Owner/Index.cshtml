                                        <i class="fas fa-qrcode me-2"></i> THANH TOÁN / TẠO MÃ QR
                                    </button>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-outline-danger w-100 py-2 fw-bold" onclick="clearPosCart()">
                                        <i class="fas fa-trash-alt"></i> Hủy đơn hàng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-warehouse">
                <div class="section-header">
                    <div class="section-title text-warning"><i class="fas fa-warehouse me-2"></i>Quản Lý Tồn Kho & Kiểm Kê</div>
                    <button class="btn btn-warning shadow-sm fw-bold">
                        <i class="fas fa-file-excel me-2"></i>Xuất báo cáo tồn
                    </button>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card stat-card bg-primary text-white border-0 shadow">
                            <h6 class="opacity-75"><i class="fas fa-coins me-2"></i>Tổng giá trị vốn tồn kho</h6>
                            <h3 class="fw-bold mb-0">@(Model.DSSanPham.Sum(x => (x.SoLuongTon ?? 0) * (x.GiaNhap ?? 0)).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card bg-success text-white border-0 shadow">
                            <h6 class="opacity-75"><i class="fas fa-boxes me-2"></i>Tổng số lượng sản phẩm</h6>
                            <h3 class="fw-bold mb-0">@(Model.DSSanPham.Sum(x => x.SoLuongTon ?? 0)) SP</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card bg-danger text-white border-0 shadow">
                            <h6 class="opacity-75"><i class="fas fa-exclamation-triangle me-2"></i>Sắp hết / Hết hàng</h6>
                            <h3 class="fw-bold mb-0">@(Model.DSSanPham.Count(x => (x.SoLuongTon ?? 0) <= 10)) Món</h3>
                        </div>
                    </div>
                </div>

                <div class="card stat-card border-0 p-0">
                    <div class="card-body table-responsive p-0" style="max-height: 60vh; overflow-y: auto;">
                        <table class="table table-hover table-custom align-middle text-center mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Mã SP</th>
                                    <th class="text-start">Tên Sản Phẩm</th>
                                    <th>Giá Nhập (Vốn)</th>
                                    <th class="bg-warning bg-opacity-25">Tồn Trên Máy</th>
                                    <th>Trạng Thái Kho</th>
                                    <th>Giá Trị Tồn</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.DSSanPham != null && Model.DSSanPham.Any())
                                {
                                    foreach (var item in Model.DSSanPham)
                                    {
                                        int tonKho = item.SoLuongTon ?? 0;
                                        decimal giaNhap = item.GiaNhap ?? 0;
                                        decimal tongGiaTri = tonKho * giaNhap;
                                        string maSP = item.MaSP != null ? item.MaSP.Trim() : "";
                                        <tr>
                                            <td class="fw-bold text-secondary">@maSP</td>
                                            <td class="text-start fw-bold text-primary">@item.TenSP</td>
                                            <td class="text-muted">@giaNhap.ToString("N0") ₫</td>
                                            <td class="fs-5 fw-bold bg-warning bg-opacity-10 text-dark">@tonKho</td>
                                            <td>
                                                @if (tonKho > 10)
                                                {
                                                    <span class="badge bg-success">An toàn</span>
                                                }
                                                else if (tonKho > 0)
                                                {

                                                    <span class="badge bg-warning text-dark">Sắp hết</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger">Hết hàng</span>
                                                }
                                            </td>
                                            <td class="fw-bold text-success">@tongGiaTri.ToString("N0") ₫</td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-warning fw-bold text-dark" onclick="openKiemKeModal('@maSP', '@item.TenSP', @tonKho)">
                                                    <i class="fas fa-balance-scale me-1"></i> Kiểm Kê
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-products">
                <div class="section-header">
                    <div class="section-title text-success"><i class="fas fa-tags me-2"></i>Quản Lý Sản Phẩm & Giá Bán</div>
                    <button class="btn btn-success shadow-sm" onclick="openProductModal()"><i class="fas fa-plus me-2"></i>Thêm Sản Phẩm Mới</button>
                </div>

                <div class="card stat-card border-0">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover table-custom align-middle text-center mb-0">
                            <thead class="table-light">
                                <tr><th>Mã SP</th><th class="text-start">Tên Sản Phẩm</th><th>Mã Vạch</th><th>ĐVT</th><th>Tồn Kho</th><th>Giá Nhập</th><th class="bg-warning text-dark">Giá Bán</th><th>Trạng Thái</th><th>Thao tác</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.DSSanPham != null && Model.DSSanPham.Any())
                                {
                                    foreach (var item in Model.DSSanPham)
                                    {
                                        string maSP = item.MaSP != null ? item.MaSP.Trim() : "";
                                        <tr>
                                            <td class="fw-bold text-secondary">@maSP</td>
                                            <td class="text-start fw-bold text-primary" id="name_text_@maSP">@item.TenSP</td>
                                            <td>@(string.IsNullOrEmpty(item.MaVach) ? "---" : item.MaVach)</td>
                                            <td>@item.DonViTinh</td>
                                            <td>
                                                @if (item.SoLuongTon > 10)
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">@item.SoLuongTon</span>
                                                }
                                                else if (item.SoLuongTon > 0)
                                                {

                                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1">@item.SoLuongTon (Sắp hết)</span>
                                                }
                                                else
                                                {

                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1">0 (Hết)</span>
                                                }
                                            </td>
                                            <td class="text-muted">@(item.GiaNhap.HasValue? item.GiaNhap.Value.ToString("N0") : "0") đ</td>
                                            <td class="text-danger fw-bold fs-6" id="price_text_@maSP">@(item.GiaBan.HasValue? item.GiaBan.Value.ToString("N0") : "0") đ</td>
                                            <td id="status_col_@maSP">
                                                <div class="form-check form-switch d-flex justify-content-center mb-0">
                                                    <input class="form-check-input cursor-pointer" type="checkbox" role="switch" style="width: 40px; height: 20px;" id="switch_@maSP" @(item.TrangThai == true ? "checked" : "") onchange="toggleProductStatus('@maSP', this)">
                                                </div>
                                                <small id="status_text_@maSP" class="text-muted fw-bold mt-1 d-block @(item.TrangThai == true ? "text-success" : "text-danger")">@(item.TrangThai == true ? "Đang bán" : "Ngừng bán")</small>
                                            </td>
                                            <td>
                                                <button class="btn btn-action text-warning me-1" data-bs-toggle="modal" data-bs-target="#editSP_@maSP" title="Sửa Giá"><i class="fas fa-edit"></i></button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="9" class="text-center text-muted py-5"><i class="fas fa-box-open fa-3x mb-3 opacity-25"></i><br />Chưa có sản phẩm nào.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-finance">
                <div class="section-header">
                    <div class="section-title text-success"><i class="fas fa-chart-pie me-2"></i>Báo cáo Tài chính & Lợi nhuận</div>
                    <button class="btn btn-outline-success shadow-sm" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>In Báo Cáo
                    </button>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card stat-card bg-white border-start border-4 border-secondary shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-box-open me-2"></i>Tổng vốn hàng đang tồn</h6>
                            <h3 class="fw-bold text-dark mb-0">@(((decimal)ViewBag.TongVonTienHang).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card bg-white border-start border-4 border-info shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-tags me-2"></i>Doanh thu ước tính (Bán hết)</h6>
                            <h3 class="fw-bold text-info mb-0">@(((decimal)ViewBag.GiaTriBanUocTinh).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card stat-card bg-white border-start border-4 border-success shadow-sm">
                            <h6 class="text-muted mb-2"><i class="fas fa-hand-holding-usd me-2"></i>Lợi nhuận gộp dự kiến</h6>
                            <h3 class="fw-bold text-success mb-0">@(((decimal)ViewBag.LoiNhuanUocTinh).ToString("N0")) ₫</h3>
                        </div>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card stat-card h-100 shadow-sm border-0">
                            <h6 class="fw-bold text-secondary mb-4"><i class="fas fa-chart-line me-2"></i>Biểu đồ dòng tiền (Mô phỏng tháng)</h6>

                            <div style="height: 300px; display: flex; align-items: flex-end; justify-content: space-around; gap: 15px; padding-bottom: 10px; border-bottom: 2px solid #f0f0f0;">
                                <div class="bg-info opacity-50 rounded-top chart-bar" style="width: 12%; height: 30%; position: relative; cursor: pointer; transition: 0.2s;" onclick="showMonthDetail(1)"><span class="position-absolute top-0 start-50 translate-middle-x mt-n4 small text-muted">30%</span></div>
                                <div class="bg-info opacity-50 rounded-top chart-bar" style="width: 12%; height: 45%; position: relative; cursor: pointer; transition: 0.2s;" onclick="showMonthDetail(2)"><span class="position-absolute top-0 start-50 translate-middle-x mt-n4 small text-muted">45%</span></div>
                                <div class="bg-info opacity-50 rounded-top chart-bar" style="width: 12%; height: 25%; position: relative; cursor: pointer; transition: 0.2s;" onclick="showMonthDetail(3)"><span class="position-absolute top-0 start-50 translate-middle-x mt-n4 small text-muted">25%</span></div>
                                <div class="bg-info opacity-50 rounded-top chart-bar" style="width: 12%; height: 65%; position: relative; cursor: pointer; transition: 0.2s;" onclick="showMonthDetail(4)"><span class="position-absolute top-0 start-50 translate-middle-x mt-n4 small text-muted">65%</span></div>
                                <div class="bg-success rounded-top shadow-sm chart-bar" style="width: 12%; height: 90%; position: relative; cursor: pointer; transition: 0.2s;" onclick="showMonthDetail(5)"><span class="position-absolute top-0 start-50 translate-middle-x mt-n4 fw-bold text-success">90%</span></div>
                            </div>
                            <div class="d-flex justify-content-space-around mt-2 text-muted small text-center fw-bold" style="gap: 15px;">
                                <div style="width: 12%">T1</div><div style="width: 12%">T2</div><div style="width: 12%">T3</div><div style="width: 12%">T4</div><div style="width: 12%" class="text-success">T5 (Hiện tại)</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card stat-card h-100 shadow-sm border-0">
                            <h6 class="fw-bold text-secondary mb-3"><i class="fas fa-star me-2 text-warning"></i>Top 5 SP Lợi nhuận cao</h6>
                            <ul class="list-group list-group-flush mt-2">
                                @{
                                    // Lọc ra top 5 sản phẩm có mức chênh lệch (Giá bán - Giá nhập) cao nhất
                                    var topProducts = Model.DSSanPham
                                    .Where(x => x.GiaBan > 0 && x.GiaNhap > 0)
                                    .OrderByDescending(x => x.GiaBan - x.GiaNhap)
                                    .Take(5)
                                    .ToList();

                                    if (topProducts.Any())
                                    {
                                        foreach (var sp in topProducts)
                                        {
                                            decimal lai = (sp.GiaBan ?? 0) - (sp.GiaNhap ?? 0);
                                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-bottom mb-2 pb-2">
                                                <div>
                                                    <div class="fw-bold text-dark text-truncate" style="max-width: 180px;" title="@sp.TenSP">@sp.TenSP</div>
                                                    <small class="text-success fw-bold"><i class="fas fa-arrow-trend-up me-1"></i>Lãi: @lai.ToString("N0") ₫ / SP</small>
                                                </div>
                                                <span class="badge bg-warning text-dark rounded-pill">VIP</span>
                                            </li>
                                        }
                                    }
                                    else
                                    {
                                        <li class="text-center text-muted mt-4">Chưa có dữ liệu giá.</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="tab-partners">
                <div class="section-header">
                    <div class="section-title text-secondary"><i class="fas fa-handshake me-2"></i>Quản Lý Nhà Cung Cấp</div>
