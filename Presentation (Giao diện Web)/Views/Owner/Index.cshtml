                                <option value="">-- Chọn Nhà cung cấp --</option>
                                @if (Model.DSNhaCungCap != null)
                                {
                                    foreach (var ncc in Model.DSNhaCungCap)
                                    {
                                        <option value="@ncc.TenNCC">@ncc.TenNCC</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="small fw-bold text-muted">Tên Sản Phẩm thực tế <span class="text-danger">*</span></label>
                            <input type="text" id="new_TenSP" class="form-control border-primary" placeholder="VD: Sơn lót chống kiềm Nippon 5L">
                        </div>

                        <div class="col-md-4">
                            <label class="small fw-bold text-primary">Mã Nội Bộ (Hệ thống tự đẻ)</label>
                            <input type="text" id="new_MaSP" class="form-control bg-warning bg-opacity-25 text-danger fw-bold" readonly placeholder="Chờ sinh mã...">
                        </div>
                        <div class="col-md-4">
                            <label class="small fw-bold text-muted">Mã Vạch (Quét trên hộp)</label>
                            <input type="text" id="new_MaVach" class="form-control" placeholder="Để trống nếu không có">
                        </div>
                        <div class="col-md-4">
                            <label class="small fw-bold text-muted">Đơn vị tính</label>
                            <input type="text" id="new_DVT" class="form-control" placeholder="Thùng, Cuộn, Tấn...">
                        </div>

                        <div class="col-md-12 mt-4 border-top pt-3">
                            <h6 class="fw-bold text-secondary mb-3"><i class="fas fa-tags me-2"></i>Quản lý theo Lô (Dành cho hàng không có mã vạch)</h6>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold text-muted">Số Lô / Mẻ luyện (Nếu có)</label>
                            <input type="text" id="new_SoLo" class="form-control" placeholder="VD: L-9988" oninput="generateLotQR()">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="w-100 text-center" id="lotQrContainer" style="display:none;">
                                <img id="lotQrImage" src="" alt="QR Lô Hàng" class="border p-2 rounded bg-white shadow-sm" style="max-width: 120px;">
                                <div class="mt-1 fw-bold text-danger small" id="lotQrText"></div>
                                <button class="btn btn-sm btn-outline-dark mt-2 w-100" onclick="window.print()"><i class="fas fa-print me-1"></i>In Tem Dán</button>
                            </div>
                            <div class="w-100 text-muted small" id="lotQrHint">
                                <i>* Nhập Số lô để hệ thống tự tạo Tem QR định danh riêng.</i>
                            </div>
                        </div>

                        <div class="col-md-12 mt-3 border-top pt-3">
                            <h6 class="fw-bold text-secondary mb-3"><i class="fas fa-coins me-2"></i>Thiết lập Giá</h6>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold text-success">Giá Nhập (Vốn) <span class="text-danger">*</span></label>
                            <input type="number" id="new_GiaNhap" class="form-control border-success fw-bold text-success" placeholder="0" min="0">
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold text-primary">Giá Bán (Lẻ) <span class="text-danger">*</span></label>
                            <input type="number" id="new_GiaBan" class="form-control border-primary fw-bold text-primary" placeholder="0" min="0">
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold" onclick="saveNewProductERP()"><i class="fas fa-save me-2"></i>Lưu Sản Phẩm</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        var allProducts = @Html.Raw(productsJson);
        var posCart = [];
        var importCart = [];

        document.addEventListener("DOMContentLoaded", function () {
            // Xử lý giữ Tab khi Reload
            var successMessage = '@(TempData["Message"] ?? "")';
            var errorMessage = '@(TempData["Error"] ?? "")';
            if (successMessage || errorMessage) {
                if (successMessage.includes("sản phẩm") || errorMessage.includes("sản phẩm")) {
                    new bootstrap.Tab(document.querySelector('a[href="#tab-products"]')).show();
                } else {
                    new bootstrap.Tab(document.querySelector('#link-tab-employees')).show();
                }
            } else {
                var activeTab = localStorage.getItem('ownerActiveTab');
                if (activeTab) {
                    var targetTab = document.querySelector('a[href="' + activeTab + '"]');
                    if(targetTab) new bootstrap.Tab(targetTab).show();
                }
            }
            document.querySelectorAll('a[data-bs-toggle="pill"]').forEach(function (tab) {
                tab.addEventListener('shown.bs.tab', function (e) {
                    localStorage.setItem('ownerActiveTab', e.target.getAttribute('href'));
                });
            });

            // Khởi tạo POS
            renderPosProducts();

            // Khởi tạo Biểu đồ Động ngay khi load trang
            var el = document.getElementById('dynamicChartArea');
            if(el) loadDynamicChart();
        });

        // ============================================================
        // [CẬP NHẬT] LOGIC BIỂU ĐỒ ĐỘNG BẰNG AJAX
        // ============================================================

        function changeChartMode() {
             var type = document.getElementById("chartTypePicker").value;
             if(type === 'daily') {
                 document.getElementById('chartDatePicker').classList.remove('d-none');
                 document.getElementById('chartYearPicker').classList.add('d-none');
                 document.getElementById('chartDescription').innerText = "Xem 7 ngày liên tiếp từ ngày đã chọn.";
             } else {
                 document.getElementById('chartDatePicker').classList.add('d-none');
                 document.getElementById('chartYearPicker').classList.remove('d-none');
                 document.getElementById('chartDescription').innerText = "Dữ liệu 12 tháng trong năm.";
             }
             loadDynamicChart();
         }

        function loadDynamicChart() {
              var type = document.getElementById("chartTypePicker").value;
              var dateVal = document.getElementById('chartDatePicker').value;
              var yearVal = document.getElementById('chartYearPicker').value;

              var d = new Date().toISOString().split('T')[0]; // Mặc định hôm nay
              var y = new Date().getFullYear();

              if(type === 'daily' && dateVal) {
                  d = dateVal;
              } else if (type === 'monthly' && yearVal) {
                  y = parseInt(yearVal);
              }

              document.getElementById('dynamicChartArea').innerHTML = `<div class="text-center py-5 text-muted"><div class="spinner-border text-primary mb-3"></div><br>Đang tải dữ liệu biểu đồ...</div>`;

              // Gọi API C# mới
              fetch(`/Owner/GetCustomChartAPI?type=${type}&selectedDate=${d}&year=${y}`)
              .then(res => res.json())
              .then(data => {
                  if(data.success) {
                      renderDynamicChartHTML(data.labels, data.revenues, data.queryKeys, data.maxRev, type, d);
                  } else {
                      document.getElementById('dynamicChartArea').innerHTML = `<div class="text-danger py-4 text-center">Lỗi: ${data.msg}</div>`;
                  }
              })
              .catch(err => {
                  document.getElementById('dynamicChartArea').innerHTML = `<div class="text-danger py-4 text-center">Lỗi kết nối máy chủ</div>`;
              });
          }

        function renderDynamicChartHTML(labels, revenues, queryKeys, maxRev, type, selectedDateStr) {
             var html = `<div style="height: 280px; display: flex; align-items: flex-end; justify-content: space-around; gap: 8px; padding-bottom: 10px; border-bottom: 2px solid var(--border-soft);">`;

             // Nếu xem ngày (7 cột) thì rộng 12%, xem tháng (12 cột) thì rộng 7%
             var colWidth = type === 'daily' ? '12%' : '7.5%';
             var today = new Date();

             for(var i=0; i<labels.length; i++) {
                 var rev = revenues[i];
                 var percent = (rev / maxRev) * 100;
                 if(percent < 5 && rev > 0) percent = 5;
                 var heightObj = rev == 0 ? "2%" : percent + "%";

                 var displayVal = rev == 0 ? "0" : (rev >= 1000000 ? (rev/1000000).toFixed(1) + "M" : (rev/1000).toFixed(0) + "k");
                 var colorClass = rev > 0 ? "bg-primary opacity-75" : "bg-secondary opacity-25";

                 // Kỹ thuật tô màu nổi bật
                 var qk = queryKeys[i];
                 if(type === 'daily') {
                     // Nếu cột đó trùng với ngày mình chọn trên ô input -> Tô xanh
                     if(qk === selectedDateStr) colorClass = "bg-success shadow-sm";
                 }
                 else if(type === 'monthly') {
                     // Nếu cột đó trùng với tháng hiện tại -> Tô vàng
                     if(i === today.getMonth() && document.getElementById('chartYearPicker').value == today.getFullYear()) {
                         colorClass = "bg-warning shadow-sm";
                     }
                 }

                 var clickFn = type === 'daily' ? `showDailyDetail('${qk}')` : `showMonthlyDetail(${qk.split(',')[0]}, ${qk.split(',')[1]})`;

                 html += `<div class="${colorClass} rounded-top chart-bar" style="width: ${colWidth}; height: ${heightObj}; position: relative; cursor: pointer; transition: 0.2s;" onclick="${clickFn}" title="Doanh thu: ${rev.toLocaleString()} đ">
                             <span class="position-absolute top-0 start-50 translate-middle-x mt-n4 fw-bold text-muted" style="font-size: 0.75rem;">${displayVal}</span>
                          </div>`;
             }
             html += `</div>`;

             html += `<div class="d-flex justify-content-space-around mt-2 text-muted text-center fw-bold" style="gap: 8px; font-size: 0.75rem;">`;
             for(var i=0; i<labels.length; i++) {
                 html += `<div style="width: ${colWidth}">${labels[i]}</div>`;
             }
             html += `</div>`;

             document.getElementById('dynamicChartArea').innerHTML = html;
         }

        // ============================================================
        // LOGIC BẢNG TOP 5 & CLICK CỘT BIỂU ĐỒ
        // ============================================================
        function updateTop5Panel(titleText, items) {
            document.getElementById('topProductsTitle').innerHTML = `<i class="fas fa-star me-2 text-warning"></i>Top 5 Bán Chạy (${titleText})`;
            var top5List = document.getElementById('topProductsList');
            top5List.innerHTML = "";

            if(items && items.length > 0) {
                var top5 = items.slice(0, 5);
                top5.forEach(item => {
                    var ten = item.tenSP || item.TenSP;
                    var dt = item.doanhThu || item.DoanhThu;
                    var sl = item.soLuong || item.SoLuong;

                    top5List.innerHTML += `
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-bottom mb-2 pb-2" style="background:transparent;">
                            <div>
                                <div class="fw-bold text-dark text-truncate" style="max-width: 180px;" title="${ten}">${ten}</div>
                                <small class="text-success fw-bold"><i class="fas fa-arrow-trend-up me-1"></i>Thu: ${dt.toLocaleString()} ₫</small>
                            </div>
                            <span class="badge bg-info text-dark rounded-pill border">SL: ${sl}</span>
                        </li>`;
                });
            } else {
                top5List.innerHTML = `<li class="text-center text-muted mt-4"><i class="fas fa-box-open fa-2x mb-2 opacity-25"></i><br>Không có giao dịch.</li>`;
            }
        }

        function showDailyDetail(dateStr) {
            Swal.fire({ title: 'Đang tải dữ liệu...', didOpen: () => Swal.showLoading() });
            fetch('/Owner/GetDailyStatsAPI?date=' + dateStr).then(res => res.json()).then(data => {
                Swal.close();
                if(data.success) {
                    document.getElementById('md_Thang').innerText = data.ngay; document.getElementById('md_DoanhThu').innerText = data.doanhThu.toLocaleString() + " ₫"; document.getElementById('md_LoiNhuan').innerText = data.loiNhuan.toLocaleString() + " ₫"; document.getElementById('md_SoHD').innerText = data.soHoaDon; document.getElementById('md_SoSP').innerText = data.tongSpBan;
                    var tbody = document.getElementById('md_ProductList'); tbody.innerHTML = "";
                    if(data.soldItems && data.soldItems.length > 0) {
                        data.soldItems.forEach(item => {
                            tbody.innerHTML += `<tr><td class="text-start ps-3"><div class="fw-bold text-dark">${item.tenSP || item.TenSP}</div><small class="text-muted">${item.maSP || item.MaSP}</small></td><td class="text-center"><span class="badge bg-info text-dark bg-opacity-10">${item.soLuong || item.SoLuong}</span></td><td class="text-end fw-bold text-success pe-3">${(item.doanhThu || item.DoanhThu).toLocaleString()} ₫</td></tr>`;
                        });
                    } else { tbody.innerHTML = `<tr><td colspan="3" class="text-center text-muted py-4">Chưa bán được món nào.</td></tr>`; }

                    updateTop5Panel(data.ngay, data.soldItems);
                    new bootstrap.Modal(document.getElementById('monthDetailModal')).show();
                } else { Swal.fire("Lỗi", data.msg, "error"); }
            });
        }

        function showMonthlyDetail(month, year) {
            Swal.fire({ title: 'Đang tải dữ liệu tháng...', didOpen: () => Swal.showLoading() });
            fetch(`/Owner/GetMonthlyStatsAPI?month=${month}&year=${year}`).then(res => res.json()).then(data => {
                Swal.close();
                if(data.success) {
                    document.getElementById('md_Thang').innerText = data.ngay; document.getElementById('md_DoanhThu').innerText = data.doanhThu.toLocaleString() + " ₫"; document.getElementById('md_LoiNhuan').innerText = data.loiNhuan.toLocaleString() + " ₫"; document.getElementById('md_SoHD').innerText = data.soHoaDon; document.getElementById('md_SoSP').innerText = data.tongSpBan;
                    var tbody = document.getElementById('md_ProductList'); tbody.innerHTML = "";
                    if(data.soldItems && data.soldItems.length > 0) {
                        data.soldItems.forEach(item => {
                            tbody.innerHTML += `<tr><td class="text-start ps-3"><div class="fw-bold text-dark">${item.tenSP || item.TenSP}</div><small class="text-muted">${item.maSP || item.MaSP}</small></td><td class="text-center"><span class="badge bg-info text-dark bg-opacity-10">${item.soLuong || item.SoLuong}</span></td><td class="text-end fw-bold text-success pe-3">${(item.doanhThu || item.DoanhThu).toLocaleString()} ₫</td></tr>`;
                        });
                    } else { tbody.innerHTML = `<tr><td colspan="3" class="text-center text-muted py-4">Không bán được sản phẩm nào.</td></tr>`; }

                    updateTop5Panel(data.ngay, data.soldItems);
                    new bootstrap.Modal(document.getElementById('monthDetailModal')).show();
                } else { Swal.fire("Lỗi", data.msg, "error"); }
            });
        }


        // ============================================================
        // LOGIC BÁN HÀNG (POS)
        // ============================================================
        function renderPosProducts() {
            var grid = document.getElementById("posProductGrid"); if (!grid) return;
            var keyword = document.getElementById("searchPosProduct").value.toLowerCase();
            grid.innerHTML = "";
            var filtered = allProducts.filter(p => p.TrangThai === true && p.SoLuongTon > 0 && (p.TenSP.toLowerCase().includes(keyword) || p.MaSP.toLowerCase().includes(keyword)));
            if(filtered.length === 0) { grid.innerHTML = `<div class="col-12 py-5 text-center text-muted">Không tìm thấy sản phẩm.</div>`; return; }
            filtered.forEach(p => {
                grid.innerHTML += `<div class="col-md-4 col-sm-6"><div class="card h-100 pos-item-card position-relative" onclick="addToPosCart('${p.MaSP}')"><div class="card-body p-3 text-center"><span class="badge bg-success position-absolute top-0 end-0 m-2">Tồn: ${p.SoLuongTon}</span><div class="mb-2"><i class="fas fa-box fa-3x text-info opacity-75"></i></div><h6 class="fw-bold mb-1 text-truncate" title="${p.TenSP}">${p.TenSP}</h6><p class="text-danger fw-bold mb-0 fs-6">${(p.GiaBan).toLocaleString()} ₫</p></div></div></div>`;
            });
        }
        function filterPosProducts() { renderPosProducts(); }
        function addToPosCart(maSP) {
            var p = allProducts.find(x => x.MaSP === maSP); if(!p) return;
            var item = posCart.find(x => x.MaSP === maSP);
            if(item) { if(item.SoLuong + 1 > p.SoLuongTon) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Vượt quá tồn!', showConfirmButton: false, timer: 2000}); return; } item.SoLuong++; }
            else { posCart.push({ MaSP: p.MaSP, TenSP: p.TenSP, GiaBan: p.GiaBan, SoLuong: 1, TonKho: p.SoLuongTon }); }
            Swal.fire({toast:true, position: 'top-end', icon: 'success', title: 'Đã thêm ' + p.TenSP, showConfirmButton: false, timer: 1000}); updatePosUI();
        }
        function updatePosUI() {
             var tbody = document.getElementById("posCartTable");
             tbody.innerHTML = "";
             var totalQ = 0; var totalM = 0;

             if(posCart.length === 0) {
                 tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-5"><i class="fas fa-cart-arrow-down fa-3x mb-2 opacity-25"></i><br>Chưa có sản phẩm nào.</td></tr>`;
             }
             else {
                 posCart.forEach((c, i) => {
                     totalQ += parseInt(c.SoLuong);
                     totalM += (c.SoLuong * c.GiaBan);

                     tbody.innerHTML += `
                         <tr class="text-center">
                             <td class="text-start ps-3">
                                 <div class="fw-bold text-dark text-truncate" style="max-width: 120px;" title="${c.TenSP}">${c.TenSP}</div>
                                 <small class="text-muted">${c.MaSP}</small>
                             </td>
                             <td>
                                 <div class="d-flex align-items-center justify-content-center">
                                     <button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${i}, -1)"><i class="fas fa-minus"></i></button>

                                     <input type="number" class="form-control form-control-sm text-center mx-1 fw-bold border bg-light" value="${c.SoLuong}" style="width: 65px; padding: 2px;" onchange="updatePosQtyDirect(${i}, this.value)" onclick="this.select()">

                                     <button class="btn btn-sm btn-light border p-1" onclick="changePosQty(${i}, 1)"><i class="fas fa-plus"></i></button>
                                 </div>
                             </td>
                             <td class="fw-bold text-danger">${(c.GiaBan * c.SoLuong).toLocaleString()}</td>
                             <td><button class="btn btn-sm text-danger" onclick="removePosItem(${i})"><i class="fas fa-times"></i></button></td>
                         </tr>`;
                 });
             }
             document.getElementById("posTotalQuantity").innerText = totalQ;
             document.getElementById("posTotalAmount").innerText = totalM.toLocaleString() + " ₫";
         }
         // Hàm mới: Xử lý khi nhân viên gõ số lượng trực tiếp bằng bàn phím
        function updatePosQtyDirect(i, val) {
            var item = posCart[i];
            var newQty = parseInt(val);

            // Nếu xóa trắng hoặc gõ tào lao, tự trả về 1
            if (isNaN(newQty) || newQty <= 0) {
                newQty = 1;
            }

            // Nếu gõ lố hàng tồn kho -> Chặn lại và gán bằng mức max tồn kho
            if (newQty > item.TonKho) {
                Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Kho chỉ còn ' + item.TonKho + ' sản phẩm!', showConfirmButton: false, timer: 3000});
                newQty = item.TonKho;
            }

            // Cập nhật lại giỏ hàng và vẽ lại màn hình
            item.SoLuong = newQty;
            updatePosUI();
        }
        function changePosQty(i, amt) { var item = posCart[i]; var newQty = item.SoLuong + amt; if(newQty <= 0) { removePosItem(i); return; } if(newQty > item.TonKho) { Swal.fire({toast:true, position: 'top-end', icon: 'error', title: 'Hết hàng!', showConfirmButton: false, timer: 2000}); return; } item.SoLuong = newQty; updatePosUI(); }
        function removePosItem(i) { posCart.splice(i, 1); updatePosUI(); }
        function clearPosCart() { if(posCart.length === 0) return; Swal.fire({title: 'Hủy đơn?', icon: 'warning', showCancelButton: true}).then((res) => { if (res.isConfirmed) { posCart = []; updatePosUI(); } }); }

        // 1. Hàm tự động sinh VietQR có chứa sẵn Tổng Tiền
            function openPaymentModal() {
            if(posCart.length === 0) return;

            // Tính tổng tiền và hiển thị lên UI
            var total = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);
            document.getElementById('qrTotalAmount').innerText = total.toLocaleString() + ' ₫';

            // [ĐÃ SỬA]: Gọi thẳng hàm generateQR() Boss viết sẵn ở dưới để nó tự bắt đúng ID qrBank và qrAccount
            generateQR();

            // Mở bảng thanh toán lên
            new bootstrap.Modal(document.getElementById('paymentModal')).show();
        }

                // 2. Hàm Tự động lưu vào Database khi Boss sửa chữ trong ô Ngân Hàng hoặc STK
              // Hàm tự động lưu thông tin Ngân hàng & STK xuống máy chủ
        function autoSaveBankInfo() {
              var bank = document.getElementById('qrBank').value.trim();
              var acc = document.getElementById('qrAccount').value.trim();
              var name = document.getElementById('qrName').value.trim(); // Bắt thêm cái tên

              if (bank && acc) {
                  // Gửi cả 3 món lên C#
                  fetch(`/Owner/SaveBankInfoAPI?nganHang=${encodeURIComponent(bank)}&stk=${encodeURIComponent(acc)}&tenChuTK=${encodeURIComponent(name)}`, { method: 'POST' })
                  .then(res => res.json())
                  .then(data => {
                      if(data.success) {
                          Swal.fire({toast: true, position: 'top-end', icon: 'success', title: 'Đã cập nhật thông tin nhận tiền!', showConfirmButton: false, timer: 1500});
                      }
                  });
              }
          }
        function generateQR() {
            var bank = document.getElementById('qrBank').value; var acc = document.getElementById('qrAccount').value; var name = document.getElementById('qrName').value; var note = document.getElementById("posNote").value || "Thanh toan mua hang";
            var totalM = posCart.reduce((sum, c) => sum + (c.SoLuong * c.GiaBan), 0);
            if(bank && acc && totalM > 0) {
                var qrUrl = `https://img.vietqr.io/image/${bank}-${acc}-compact2.png?amount=${totalM}&addInfo=${encodeURIComponent(note)}&accountName=${encodeURIComponent(name)}`;
                document.getElementById('qrImage').src = qrUrl; document.getElementById('qrImageContainer').style.display = 'block';
            } else { document.getElementById('qrImageContainer').style.display = 'none'; }
        }
