                            <div class="d-flex justify-content-between mb-2 small text-muted">
                                <span>Tổng số lượng:</span>
                                <span class="fw-bold text-dark" id="posTotalQuantity">0</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-end mb-4">
                                <span class="h6 mb-0 fw-bold">Khách cần trả:</span>
                                <span class="h2 mb-0 fw-bold text-danger" id="posTotalAmount">0 ₫</span>
                            </div>

                            <div class="mb-3">
