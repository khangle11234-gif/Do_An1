                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1">@item.SoLuongTon (Sắp hết)</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1">0 (Hết)</span>
                                                }
                                            </td>
                                            <td class="text-muted">@(item.GiaNhap.HasValue? item.GiaNhap.Value.ToString("N0") : "0") đ</td>
                                            <td class="text-danger fw-bold fs-6" id="price_text_@maSP">@(item.GiaBan.HasValue? item.GiaBan.Value.ToString("N0") : "0") đ</td>
