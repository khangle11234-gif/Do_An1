@model Business.DTOs.Input.LoginRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống | Smart Warehouse</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            /* Hình nền kho hàng (Lấy từ internet) */
            background-image: url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80');
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        /* Lớp phủ màu tối để chữ dễ đọc hơn */
        .overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(4px); /* Làm mờ hình nền nhẹ */
        }

        /* Khung đăng nhập hiệu ứng kính */
        .login-box {
            position: relative;
            width: 400px;
            background: rgba(255, 255, 255, 0.15); /* Trong suốt */
            border-radius: 20px;
            padding: 50px 40px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            backdrop-filter: blur(15px); /* Hiệu ứng kính mờ cực đẹp */
            color: white;
        }

        h2 {
            text-align: center;
            margin-bottom: 40px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        /* Ô nhập liệu hiện đại */
        .input-group {
            position: relative;
            margin-bottom: 30px;
        }

            .input-group input {
                width: 100%;
                padding: 10px 0;
                font-size: 16px;
                color: #fff;
                border: none;
                border-bottom: 1px solid #fff;
                background: transparent;
                outline: none;
            }

            .input-group label {
                position: absolute;
                top: 0;
                left: 0;
                padding: 10px 0;
                font-size: 16px;
                color: #ddd;
                pointer-events: none;
                transition: 0.5s;
            }

            /* Hiệu ứng khi click vào ô nhập */
            .input-group input:focus ~ label,
            .input-group input:valid ~ label {
                top: -25px;
                left: 0;
                color: #03e9f4; /* Màu xanh neon */
                font-size: 12px;
            }

        /* Nút đăng nhập */
        .btn-submit {
            position: relative;
            display: inline-block;
            padding: 10px 20px;
            color: #fff; /* Màu chữ */
            font-size: 16px;
            text-decoration: none;
            text-transform: uppercase;
            overflow: hidden;
            transition: 0.5s;
            margin-top: 20px;
            letter-spacing: 4px;
            background: #03e9f4; /* Nền xanh */
            border: none;
            border-radius: 5px;
            width: 100%;
            cursor: pointer;
            box-shadow: 0 0 5px #03e9f4, 0 0 25px #03e9f4; /* Hiệu ứng phát sáng */
            font-weight: bold;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5); /* Đổ bóng chữ để dễ đọc trên nền sáng */
        }

            .btn-submit:hover {
                background: #fff;
                color: #03e9f4;
                box-shadow: 0 0 5px #03e9f4, 0 0 25px #03e9f4, 0 0 50px #03e9f4;
            }

        .alert-error {
            background: rgba(255, 0, 0, 0.6);
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 20px;
            text-align: center;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="overlay"></div>

    <div class="login-box">
        <h2>ĐĂNG NHẬP</h2>

        <form asp-action="Login" method="post">
            @if (ViewBag.Error != null)
            {
                <div class="alert-error">
                    <i class="fas fa-exclamation-triangle"></i> @ViewBag.Error
                </div>
            }

            <div class="input-group">
                <input asp-for="TenDangNhap" type="text" required autocomplete="off">
                <label>Tên đăng nhập</label>
            </div>

            <div class="input-group">
                <input asp-for="MatKhau" type="password" required>
                <label>Mật khẩu</label>
            </div>

            <button type="submit" class="btn-submit">
                VÀO HỆ THỐNG
            </button>

            <div style="text-align: center; margin-top: 20px;">
                <a href="#" style="color: #ddd; font-size: 13px; text-decoration: none;">Quên mật khẩu?</a>
            </div>
        </form>
    </div>
</body>
</html>